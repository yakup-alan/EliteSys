goto windows_optimize_menu

:detect_nic
for /f "tokens=*" %%I in ('powershell -command "Get-NetAdapter | Where-Object { $_.Status -eq 'Up' } | Select-Object -ExpandProperty InterfaceGuid"') do (
    set "NIC_ID={%%I}"
    goto nic_done
)
:nic_done
echo Aktif NIC GUID: %NIC_ID%

:windows_optimize
cls
echo.
echo [1/9] Sistem önbellekleri temizleniyor...
rundll32.exe advapi32.dll,ProcessIdleTasks >nul 2>&1
ipconfig /flushdns >nul 2>&1

echo [2/9] Disk performansı optimize ediliyor...
powercfg /setactive 8c5e7fda-e8bf-4a96-9a85-a6e23a8c635c >nul 2>&1
fsutil behavior set memoryusage 2 >nul 2>&1

echo [3/9] Ağ optimizasyonları uygulanıyor...
netsh int tcp set global autotuninglevel=restricted >nul 2>&1
netsh int tcp set global rss=enabled >nul 2>&1

echo [4/9] Kayıt defteri optimizasyonları...
reg add "HKLM\SYSTEM\CurrentControlSet\Control\Session Manager\Memory Management" /v DisablePagingExecutive /t REG_DWORD /d 1 /f >nul 2>&1
reg add "HKLM\SYSTEM\CurrentControlSet\Control\Session Manager\Memory Management" /v LargeSystemCache /t REG_DWORD /d 1 /f >nul 2>&1

echo [5/9] Görsel efektler ve tema ayarları yapılıyor...
reg add "HKCU\Software\Microsoft\Windows\CurrentVersion\Explorer\VisualEffects" /v VisualFXSetting /t REG_DWORD /d 2 /f >nul 2>&1
reg add "HKCU\Software\Microsoft\Windows\CurrentVersion\Themes\Personalize" /v EnableTransparency /t REG_DWORD /d 0 /f >nul 2>&1
reg add "HKCU\Software\Microsoft\Windows\CurrentVersion\Themes\Personalize" /v AppsUseLightTheme /t REG_DWORD /d 0 /f >nul 2>&1
reg add "HKCU\Software\Microsoft\Windows\CurrentVersion\Themes\Personalize" /v SystemUsesLightTheme /t REG_DWORD /d 0 /f >nul 2>&1

echo [6/9] Sanal bellek ayarlanıyor...
wmic computersystem where name="%computername%" set AutomaticManagedPagefile=False >nul 2>&1
wmic pagefileset where name="C:\\pagefile.sys" set InitialSize=1024,MaximumSize=24576 >nul 2>&1

echo [7/9] Güç ve hazırda bekletme ayarları optimize ediliyor...
powercfg /h off >nul 2>&1
powercfg /setacvalueindex SCHEME_BALANCED SUB_PROCESSOR IDLEDISABLE 000 >nul 2>&1

echo [8/9] Multimedya ve ileri optimizasyonlar uygulanıyor...
reg add "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile" /v NetworkThrottlingIndex /t REG_DWORD /d 4294967295 /f >nul 2>&1
reg add "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile" /v SystemResponsiveness /t REG_DWORD /d 0 /f >nul 2>&1
reg add "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile\Tasks\Games" /v Affinity /t REG_DWORD /d 0 /f >nul 2>&1
reg add "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile\Tasks\Games" /v Background Only /t REG_SZ /d False /f >nul 2>&1
reg add "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile\Tasks\Games" /v "Clock Rate" /t REG_DWORD /d 10000 /f >nul 2>&1
reg add "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile\Tasks\Games" /v "GPU Priority" /t REG_DWORD /d 8 /f >nul 2>&1
reg add "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile\Tasks\Games" /v Priority /t REG_DWORD /d 6 /f >nul 2>&1
reg add "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile\Tasks\Games" /v "Scheduling Category" /t REG_SZ /d High /f >nul 2>&1
reg add "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Multimedia\SystemProfile\Tasks\Games" /v "SFIO Priority" /t REG_SZ /d High /f >nul 2>&1
reg add "HKLM\SYSTEM\CurrentControlSet\Control\Power\PowerThrottling" /v PowerThrottlingOff /t REG_DWORD /d 1 /f >nul 2>&1
reg add "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\DriverSearching" /v SearchOrderConfig /t REG_DWORD /d 0 /f >nul 2>&1
reg add "HKLM\SYSTEM\Setup" /v RespecializeCmdLine /t REG_SZ /d "" /f >nul 2>&1
reg add "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Setup\Sysprep\Settings\sppnp" /v DoNotCleanUpNonPresentDevices /t REG_DWORD /d 1 /f >nul 2>&1
reg add "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Setup\Sysprep\Settings\sppnp" /v PersistAllDeviceInstalls /t REG_DWORD /d 1 /f >nul 2>&1
reg add "HKLM\System\CurrentControlSet\Control\DeviceGuard\Scenarios\HypervisorEnforcedCodeIntegrity" /v HypervisorEnforcedCodeIntegrity /t REG_DWORD /d 0 /f >nul 2>&1

if defined NIC_ID (
  reg add "HKLM\SYSTEM\CurrentControlSet\Services\Tcpip\Parameters\Interfaces\%NIC_ID%" /v TcpAckFrequency /t REG_DWORD /d 1 /f >nul 2>&1
  reg add "HKLM\SYSTEM\CurrentControlSet\Services\Tcpip\Parameters\Interfaces\%NIC_ID%" /v TCPNoDelay /t REG_DWORD /d 1 /f >nul 2>&1
)

echo [9/9] Boot seçenekleri ayarlanıyor...
reg add "HKLM\SYSTEM\CurrentControlSet\Control\DeviceGuard" /v HypervisorEnforcedCodeIntegrity /t REG_DWORD /d 0 /f >nul 2>&1
bcdedit /set {current} nx AlwaysOff >nul 2>&1
bcdedit /set useplatformclock no >nul 2>&1
bcdedit /set useplatformtick yes >nul 2>&1
bcdedit /set disabledynamictick yes >nul 2>&1
bcdedit /set hypervisorlaunchtype off >nul 2>&1

echo.
echo 	╔════════════════════════════════════════════════════════╗
echo 	║           OPTİMİZASYON TAMAMLANDI                    ║
echo 	╠════════════════════════════════════════════════════════╣
echo 	║ [] Performans artırıldı                               ║
echo 	║ [] Kararlılık ayarları uygulandı                      ║
echo 	╚════════════════════════════════════════════════════════╝
echo.

:restart_prompt
set /p restart=Bilgisayarı şimdi yeniden başlatmak ister misiniz? (E/H): 
