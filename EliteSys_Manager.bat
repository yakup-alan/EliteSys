:edge_setup
cls
echo.
echo  [ Microsoft Edge (Türkçe) Yükleniyor ]
echo.

set "EDGE_EXE=%ProgramFiles(x86)%\Microsoft\Edge\Application\msedge.exe"
set "BACKUP_PERFORMED=0"

if not exist "%EDGE_EXE%" (
    echo Mevcut bir Microsoft Edge kurulumu bulunamadı.
    goto edge_install
)

echo Mevcut bir Microsoft Edge kurulumu bulundu.
tasklist /FI "IMAGENAME eq msedge.exe" 2>NUL | find /I /N "msedge.exe">NUL
if "%ERRORLEVEL%"=="0" (
    echo.
    echo [UYARI] Yedekleme ve kurulumdan önce Microsoft Edge'in tamamen kapatılması gerekiyor.
    echo Lütfen tüm Edge pencerelerini kapattıktan sonra bir tuşa basın.
    pause >nul
)

echo.
choice /c EH /n /m "Ayarlar, eklentiler ve kullanıcı verileri yedeklensin mi? [E/H]: "
if errorlevel 2 goto edge_install
if errorlevel 1 goto edge_backup

:edge_backup
echo.
echo Kullanıcı verileri yedekleniyor... Lütfen bekleyiniz.
set "EDGE_USER_DATA=%LOCALAPPDATA%\Microsoft\Edge\User Data"
set "BACKUP_PATH=%USERPROFILE%\Desktop\Tarayici_Yedekleri\Edge"
robocopy "%EDGE_USER_DATA%" "%BACKUP_PATH%" /E /R:1 /W:1 /NFL /NDL /NJH /NJS >nul
if %errorlevel% LSS 8 (
    echo Yedekleme tamamlandı. Yedekleriniz "%BACKUP_PATH%" klasörüne kaydedildi.
    set "BACKUP_PERFORMED=1"
) else (
    echo [HATA] Yedekleme sırasında bir sorun oluştu. Kuruluma devam ediliyor.
)
echo.
goto edge_install

:edge_install
echo.
echo Edge indiriliyor, lütfen bekleyiniz...
powershell -command "$ProgressPreference = 'SilentlyContinue'; Invoke-WebRequest -Uri 'https://c2rsetup.officeapps.live.com/c2r/downloadEdge.aspx?platform=Default&source=EdgeStablePage&Channel=Stable&language=tr&brand=M100' -OutFile '%Temp%\EdgeSetup.exe'"
if not exist "%Temp%\EdgeSetup.exe" (
    echo [HATA] Edge indirilemedi! Lütfen internet bağlantınızı kontrol edin.
    pause
    goto browser_setup
)
echo.
echo Kurulum başlatılıyor...
start "" /wait "%Temp%\EdgeSetup.exe"
echo.
echo [BILGI] Microsoft Edge başarıyla yüklendi!
del /q "%Temp%\EdgeSetup.exe" >nul 2>&1

if "%BACKUP_PERFORMED%"=="1" (
    goto edge_restore
) else (
    goto edge_disable_updates
)

:edge_restore
echo.
choice /c EH /n /m "Yedeklenen kullanıcı verileri şimdi geri yüklensin mi? [E/H]: "
if errorlevel 2 goto edge_disable_updates
if errorlevel 1 (
    echo Veriler geri yükleniyor... Lütfen bekleyiniz.
    robocopy "%BACKUP_PATH%" "%EDGE_USER_DATA%" /E /R:1 /W:1 /NFL /NDL /NJH /NJS >nul
    if %errorlevel% LSS 8 (
        echo [BILGI] Veriler başarıyla geri yüklendi.
    ) else (
        echo [HATA] Geri yükleme sırasında bir sorun oluştu. Verileriniz hala "%BACKUP_PATH%" klasöründe güvende.
    )
)
goto edge_disable_updates

:edge_disable_updates
echo.
echo [BILGI] Otomatik güncellemeler devre dışı bırakılıyor...
reg add "HKLM\SOFTWARE\Policies\Microsoft\EdgeUpdate" /v UpdateDefault /t REG_DWORD /d 0 /f >nul 2>&1
sc config edgeupdate start= disabled >nul 2>&1
sc config edgeupdatem start= disabled >nul 2>&1
schtasks /change /tn "MicrosoftEdgeUpdateTaskMachineCore" /disable >nul 2>&1
schtasks /change /tn "MicrosoftEdgeUpdateTaskMachineUA" /disable >nul 2>&1
echo [BILGI] Microsoft Edge güncellemeleri devre dışı bırakıldı.
goto edge_end

:edge_end
pause
goto browser_setup

:chrome_menu
cls
echo.
echo 	╔═══════════════════════════════════════════════════════╗
echo 	║         GOOGLE CHROME YÖNETİM ARACI                 ║
echo 	╠═══════════════════════════════════════════════════════╣
echo 	║  [1]  Chrome Kur / Güncelle                         ║
echo 	║  [2]  Ayarları Yedekle                              ║
echo 	║  [3]  Ayarları Geri Yükle                           ║
echo 	║  [4]  Güncellemeleri Kapat / Aç                     ║
echo 	║  [5]  Başlangıçta Çalıştır Ayarla                   ║
echo 	║  [6]  Chrome'u Tamamen Kaldır                       ║
echo 	║  [7]  Önceki Menüye Dön                             ║
echo 	╚═══════════════════════════════════════════════════════╝
echo.
set /p chrome_choice=">> Seçiminiz (1-7): "

if "%chrome_choice%"=="1" goto chrome_install
if "%chrome_choice%"=="2" goto chrome_backup_settings
if "%chrome_choice%"=="3" goto chrome_restore_settings
if "%chrome_choice%"=="4" goto chrome_update_settings
if "%chrome_choice%"=="5" goto chrome_startup_settings
if "%chrome_choice%"=="6" goto chrome_uninstall_chrome
if "%chrome_choice%"=="7" goto browser_setup

echo Geçersiz seçim!
pause
goto chrome_menu

:chrome_install
cls
echo [BİLGİ] Chrome işlemleri sonlandırılıyor...
taskkill /f /im chrome.exe >nul 2>&1
taskkill /f /im GoogleUpdate.exe >nul 2>&1

set "chromeURL=https://dl.google.com/chrome/install/latest/chrome_installer.exe"
set "chromeInstaller=%TEMP%\chrome_installer.exe"

echo [BİLGİ] Chrome kurucusu indiriliyor...

curl -L -o "%chromeInstaller%" "%chromeURL%" >nul 2>&1 || (
    echo [UYARI] curl başarısız oldu, certutil ile deneniyor...
    certutil -urlcache -split -f "%chromeURL%" "%chromeInstaller%" >nul 2>&1 || (
        echo [UYARI] certutil başarısız oldu, PowerShell ile deneniyor...
        powershell -Command "(New-Object System.Net.WebClient).DownloadFile('%chromeURL%', '%chromeInstaller%')"
    )
)

if not exist "%chromeInstaller%" (
    echo [HATA] Chrome indirilemedi! Manuel indirme sayfası açılıyor...
    start https://www.google.com/chrome/
    pause
    goto browser_setup
)

echo [BİLGİ] Chrome kurulumu başlatılıyor...
start /wait "" "%chromeInstaller%" /silent /install

timeout /t 15 >nul
reg query "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\App Paths\chrome.exe" >nul 2>&1
if %errorlevel% neq 0 (
    echo [HATA] Kurulum başarısız! Manuel kurulum önerilir.
    start "" "%chromeInstaller%"
    pause
    goto browser_setup
)

reg add "HKCU\Software\Google\Chrome\TriggeredReset" /v "AttemptTriggeredReset" /t REG_DWORD /d 0 /f >nul 2>&1

echo [BİLGİ] Chrome başarıyla kuruldu/güncellendi!
pause
goto browser_setup

:chrome_backup_settings
cls
set "backupDir=%USERPROFILE%\Chrome_Backup_%DATE:/=-%_%TIME::=-%"
mkdir "%backupDir%" >nul 2>&1

echo [BİLGİ] Chrome ayarları yedekleniyor...
xcopy "%LOCALAPPDATA%\Google\Chrome\User Data" "%backupDir%\User Data" /E /I /H /Y >nul 2>&1
if exist "%USERPROFILE%\AppData\Local\Google\Chrome\Extensions" (
    xcopy "%USERPROFILE%\AppData\Local\Google\Chrome\Extensions" "%backupDir%\Extensions" /E /I /H /Y >nul 2>&1
)

echo [BİLGİ] Yedekleme tamamlandı: %backupDir%
pause
goto browser_setup

:chrome_restore_settings
cls
set /p backupDir=Yedek klasör yolunu girin: 

if not exist "%backupDir%\User Data" (
    echo [HATA] Geçerli yedek bulunamadı!
    pause
    goto browser_setup
)

echo [BİLGİ] Chrome ayarları geri yükleniyor...

taskkill /f /im chrome.exe >nul 2>&1
timeout /t 3 >nul

robocopy "%backupDir%\User Data" "%LOCALAPPDATA%\Google\Chrome\User Data" /E /COPYALL /R:1 /W:1 >nul 2>&1
if exist "%backupDir%\Extensions" (
    robocopy "%backupDir%\Extensions" "%USERPROFILE%\AppData\Local\Google\Chrome\Extensions" /E /COPYALL /R:1 /W:1 >nul 2>&1
)

echo [BİLGİ] Geri yükleme tamamlandı!
pause
goto browser_setup

:chrome_update_settings
cls
echo.
echo  === GÜNCELLEME AYARLARI ===
echo  1. Güncellemeleri Tamamen Devre Dışı Bırak
echo  2. Güncellemeleri Etkinleştir
echo  3. Ana Menüye Dön
echo.
set /p update_choice=">> Seçiminiz (1-3): "

if "%update_choice%"=="1" (
    echo [BİLGİ] Güncellemeler devre dışı bırakılıyor...
    reg add "HKLM\SOFTWARE\Policies\Google\Update" /v UpdateDefault /t REG_DWORD /d 0 /f >nul 2>&1
    sc config gupdate start= disabled >nul 2>&1
    sc config gupdatem start= disabled >nul 2>&1
    schtasks /change /tn "GoogleUpdateTaskMachineCore" /disable >nul 2>&1
    schtasks /change /tn "GoogleUpdateTaskMachineUA" /disable >nul 2>&1
    echo [BİLGİ] Güncellemeler devre dışı bırakıldı!
) else if "%update_choice%"=="2" (
    echo [BİLGİ] Güncellemeler etkinleştiriliyor...
    reg delete "HKLM\SOFTWARE\Policies\Google\Update" /v UpdateDefault /f >nul 2>&1
    sc config gupdate start= demand >nul 2>&1
    sc config gupdatem start= demand >nul 2>&1
    schtasks /change /tn "GoogleUpdateTaskMachineCore" /enable >nul 2>&1
    schtasks /change /tn "GoogleUpdateTaskMachineUA" /enable >nul 2>&1
    echo [BİLGİ] Güncellemeler etkinleştirildi!
)
pause
goto ana_menu

:chrome_startup_settings
cls
echo.
echo  === BAŞLANGIÇ AYARLARI ===
echo  1. Chrome'u Başlangıçta Aç
echo  2. Başlangıçtan Kaldır
echo  3. Ana Menüye Dön
echo.
set /p startup_choice=">> Seçiminiz (1-3): "

if "%startup_choice%"=="1" (
    echo [BİLGİ] Başlangıca ekleniyor...
    reg add "HKCU\Software\Microsoft\Windows\CurrentVersion\Run" /v GoogleChromeAutoLaunch /t REG_SZ /d "\"C:\Program Files\Google\Chrome\Application\chrome.exe\" --restore-last-session" /f >nul 2>&1
    echo [BİLGİ] Başlangıca eklendi!
) else if "%startup_choice%"=="2" (
    echo [BİLGİ] Başlangıçtan kaldırılıyor...
    reg delete "HKCU\Software\Microsoft\Windows\CurrentVersion\Run" /v GoogleChromeAutoLaunch /f >nul 2>&1
    echo [BİLGİ] Başlangıçtan kaldırıldı!
)
pause
goto ana_menu

:chrome_uninstall_chrome
cls
echo [UYARI] Chrome tamamen kaldırılacak, devam edilsin mi? (E/H)
set /p confirm=Seçiminiz: 
if /i "%confirm%" neq "E" goto ana_menu

echo [BİLGİ] Chrome kaldırılıyor...
taskkill /f /im chrome.exe >nul 2>&1
taskkill /f /im GoogleUpdate.exe >nul 2>&1

if exist "%ProgramFiles%\Google\Chrome\Application\" (
    "%ProgramFiles%\Google\Chrome\Application\%\Installer\setup.exe" --uninstall --force-uninstall --multi-install --chrome --system-level
)

reg delete "HKLM\SOFTWARE\Google\Chrome" /f >nul 2>&1
reg delete "HKCU\Software\Google\Chrome" /f >nul 2>&1

echo [UYARI] Kullanıcı verileri de silinsin mi? (E/H)
set /p delete_data=Seçiminiz: 
if /i "%delete_data%"=="E" (
    rd /s /q "%LOCALAPPDATA%\Google\Chrome" >nul 2>&1
)

echo [BİLGİ] Chrome başarıyla kaldırıldı!
pause
goto browser_setup

