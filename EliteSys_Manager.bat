echo [BİLGİ] Lütfen işlem tamamlanana kadar bekleyin...
echo.
set "tempdir=%TEMP%\defender_script"
if not exist "%tempdir%" mkdir "%tempdir%"
echo [INFO] ZIP dosyası indiriliyor...
powershell -Command "Invoke-WebRequest -Uri 'https://codeload.github.com/ionuttbara/windows-defender-remover/zip/refs/tags/release_def_12_8' -OutFile '%tempdir%\defender-remover.zip'"

if errorlevel 1 (
    echo [HATA] İndirme başarısız oldu. Lütfen internet bağlantınızı kontrol edin.
    pause
    goto defender_menu
)

echo [INFO] ZIP arşivi açılıyor...
powershell -Command "Expand-Archive -Path '%tempdir%\defender-remover.zip' -DestinationPath '%tempdir%' -Force"

if errorlevel 1 (
    echo [HATA] ZIP açılamadı. Arşiv bozuk olabilir.
    pause
    goto defender_menu
)

del /f /q "%tempdir%\defender-remover.zip"
for /d %%D in ("%tempdir%\*") do (
    set "DIR=%%D"
)

pushd "%DIR%"
echo [INFO] Script başlatılıyor...
if exist Script_Run.bat (
    call Script_Run.bat
) else (
    echo [HATA] Script_Run.bat bulunamadı. Arşiv içeriği hatalı olabilir.
    pause
)
popd

echo [INFO] Geçici dosyalar temizleniyor...
rmdir /s /q "%tempdir%"

goto defender_menu

