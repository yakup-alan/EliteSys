:NVIDIA_SETTINGS
cls
echo.
echo    ╔══════════════════════════════════════════════════════════╗
echo    ║              NVIDIA GPU CONFIGFLAGS SIFIRLAMA            ║
echo    ╠══════════════════════════════════════════════════════════╣
echo    ║    NVIDIA ekran kartı ConfigFlags değerleri sıfırlanıyor ║
echo    ║ Etki:PCI kayıtlarında NVIDIA aygıtları yeniden tanıtılır ║
echo    ║ Not: Yönetici hakları gerektirir                         ║
echo    ╚══════════════════════════════════════════════════════════╝
echo.

echo İşlem başlatılıyor...
timeout /t 2 /nobreak >nul

net session >nul 2>&1
if %errorlevel% neq 0 (
    echo    ╔══════════════════════════════════════════════════════════╗
    echo    ║              YÖNETİCİ HAKLARI GEREKİYOR                  ║
    echo    ╠══════════════════════════════════════════════════════════╣
    echo    ║ Bu işlem yönetici hakları gerektirir.                    ║
    echo    ║ Script yeniden başlatılacak...                           ║
    echo    ╚══════════════════════════════════════════════════════════╝
    timeout /t 3 /nobreak >nul
    powershell -Command "Start-Process cmd -ArgumentList '/c \"%~f0\" && goto :NVIDIA_SETTINGS' -Verb RunAs"
    exit /b
)

echo NVIDIA kayıt defteri anahtarları taranıyor...
set "nvidia_count=0"
set "reset_count=0"

for /f "tokens=*" %%i in ('reg query "HKEY_LOCAL_MACHINE\SYSTEM\CurrentControlSet\Enum\PCI" /s /f "NVIDIA" 2^>nul') do (
    set /a nvidia_count+=1
    echo Tarama yapılıyor: %%i
    reg query "%%i" /v "ConfigFlags" >nul 2>&1
    if !errorlevel! equ 0 (
        echo ConfigFlags bulundu, sıfırlanıyor...
        reg add "%%i" /v "ConfigFlags" /t REG_DWORD /d "0" /f >nul 2>&1
        if !errorlevel! equ 0 (
            set /a reset_count+=1
            echo  Başarıyla sıfırlandı
        ) else (
            echo  Sıfırlama başarısız
        )
    )
)

echo.
echo    ╔══════════════════════════════════════════════════════════╗
echo    ║                    İŞLEM TAMAMLANDI                      ║
echo    ╠══════════════════════════════════════════════════════════╣
echo    ║ Taranan NVIDIA anahtarları: %nvidia_count%                 ║
echo    ║ Sıfırlanan ConfigFlags: %reset_count%                      ║
echo    ║                                                          ║
echo    ║ NVIDIA ConfigFlags değerleri başarıyla sıfırlandı.       ║
echo    ║ Değişikliklerin etkili olması için sistemi yeniden       ║
echo    ║ başlatmanız önerilir.                                    ║
echo    ╚══════════════════════════════════════════════════════════╝
echo.
pause
goto nvidia_pan

:SYSTEM_sysprep
cls
echo.
echo    ╔══════════════════════════════════════════════════════════╗
echo    ║               SİSTEM HAZIRLAMA TEMİZLİĞİ                 ║
echo    ╠══════════════════════════════════════════════════════════╣
echo    ║ İşlem: Sysprep ve sistem özel ayarları temizleniyor      ║
echo    ║ Etki: Sistem hazırlama ayarları sıfırlanır               ║
echo    ║ Not: OEM ayarları ve özelleştirmeler temizlenir          ║
echo    ╚══════════════════════════════════════════════════════════╝
echo.

echo Sistem hazırlama ayarları temizleniyor...
timeout /t 2 /nobreak >nul

net session >nul 2>&1
if %errorlevel% neq 0 (
    echo Yönetici hakları gerekiyor. Script yeniden başlatılacak...
    powershell -Command "Start-Process cmd -ArgumentList '/c \"%~f0\" && goto :SYSTEM_sysprep' -Verb RunAs"
    exit /b
)

echo Kayıt defteri ayarları güncelleniyor...

set "success_count=0"
set "total_operations=0"

reg add "HKEY_LOCAL_MACHINE\SYSTEM\Setup" /v "RespecializeCmdLine" /t REG_SZ /d "" /f >nul 2>&1
if !errorlevel! equ 0 (set /a success_count+=1) else (echo  RespecializeCmdLine temizlenemedi)
set /a total_operations+=1

reg add "HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows\CurrentVersion\Setup\Sysprep\Settings\sppnp" /v "DoNotCleanUpNonPresentDevices" /t REG_DWORD /d 1 /f >nul 2>&1
if !errorlevel! equ 0 (set /a success_count+=1) else (echo  DoNotCleanUpNonPresentDevices ayarlanamadı)
set /a total_operations+=1

reg add "HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows\CurrentVersion\Setup\Sysprep\Settings\sppnp" /v "PersistAllDeviceInstalls" /t REG_DWORD /d 1 /f >nul 2>&1
if !errorlevel! equ 0 (set /a success_count+=1) else (echo  PersistAllDeviceInstalls ayarlanamadı)
set /a total_operations+=1

reg delete "HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows\CurrentVersion\OEMInformation" /f >nul 2>&1
if !errorlevel! equ 0 (set /a success_count+=1) else (echo  OEM bilgileri temizlendi veya zaten yoktu)
set /a total_operations+=1

echo.
echo    ╔══════════════════════════════════════════════════════════╗
echo    ║                   İŞLEM TAMAMLANDI                       ║
echo    ╠══════════════════════════════════════════════════════════╣
echo    ║ Başarılı işlemler: %success_count%/%total_operations%          ║
echo    ║                                                          ║
echo    ║ Sistem hazırlama ayarları başarıyla temizlendi.          ║
echo    ║ OEM bilgileri ve sysprep ayarları sıfırlandı.            ║
echo    ╚══════════════════════════════════════════════════════════╝
echo.
pause
goto nvidia_pan

:GAMING_OVERLAY
cls
echo.
echo    ╔══════════════════════════════════════════════════════════╗
echo    ║                GAMING OVERLAY KAPATMA                    ║
echo    ╠══════════════════════════════════════════════════════════╣
echo    ║ İşlem: Oyun kayıt ve overlay özellikleri kapatılıyor     ║
echo    ║ Etki: Performans artışı ve müdahale azaltma              ║
echo    ║ Not: Game Bar, kayıt ve bildirim özellikleri devre dışı  ║
echo    ╚══════════════════════════════════════════════════════════╝
echo.

echo Oyun overlay ayarları kapatılıyor...
timeout /t 2 /nobreak >nul

set "success_count=0"
set "total_operations=0"

reg add "HKEY_CURRENT_USER\Software\Microsoft\Windows\CurrentVersion\GameDVR" /v "AppCaptureEnabled" /t REG_DWORD /d 0 /f >nul 2>&1
if !errorlevel! equ 0 (set /a success_count+=1) else (echo  GameDVR devre dışı bırakılamadı)
set /a total_operations+=1

reg add "HKEY_CURRENT_USER\System\GameConfigStore" /v "GameDVR_Enabled" /t REG_DWORD /d 0 /f >nul 2>&1
if !errorlevel! equ 0 (set /a success_count+=1) else (echo  GameDVR_Enabled zaten kapalı)
set /a total_operations+=1

reg add "HKEY_CURRENT_USER\Software\Microsoft\GameBar" /v "AllowAutoGameMode" /t REG_DWORD /d 0 /f >nul 2>&1
if !errorlevel! equ 0 (set /a success_count+=1) else (echo  GameBar ayarları güncellendi)
set /a total_operations+=1

reg add "HKEY_LOCAL_MACHINE\SOFTWARE\Policies\Microsoft\Windows\GameDVR" /v "AllowGameDVR" /t REG_DWORD /d 0 /f >nul 2>&1
if !errorlevel! equ 0 (set /a success_count+=1) else (echo  GameDVR politikası ayarlandı)
set /a total_operations+=1

echo.
echo    ╔══════════════════════════════════════════════════════════╗
echo    ║                    İŞLEM TAMAMLANDI                      ║
echo    ╠══════════════════════════════════════════════════════════╣
echo    ║ Başarılı işlemler: %success_count%/%total_operations%          ║
echo    ║                                                          ║
echo    ║ Tüm oyun overlay ve kayıt özellikleri devre dışı         ║
echo    ║ bırakıldı. Performans artışı sağlanacaktır.              ║
echo    ╚══════════════════════════════════════════════════════════╝
echo.
pause
goto nvidia_pan

:optimize_APPLY_ALL
cls
echo.
echo    ╔══════════════════════════════════════════════════════════╗
echo    ║               TÜM OPTİMİZASYON AYARLARI                  ║
echo    ╠══════════════════════════════════════════════════════════╣
echo    ║ Tüm sistem optimizasyon ayarları uygulanacak:            ║
