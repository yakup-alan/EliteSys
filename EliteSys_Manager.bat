set "durum=KAPALI"
set "windows_tuslari=KAPALI"
set "proses=KAPALI"
set "zoom_seviyesi=Bilinmiyor"
set "hotkeys=KAPALI"
set "win_keys_policy=KAPALI"
set "ease_of_access=KAPALI"
set "magnifier_policy=KAPALI"

