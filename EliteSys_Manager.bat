:defender_durum_raporu
set "rapor_dosyasi=Defender_Durum_Raporu.txt"
echo ====================================================== > "%rapor_dosyasi%"
echo          WINDOWS DEFENDER DETAYLI DURUM RAPORU         >> "%rapor_dosyasi%"
echo          Oluşturulma Tarihi: %date% %time%             >> "%rapor_dosyasi%"
