:brave_setup
@echo off
title Brave Installer
setlocal enabledelayedexpansion

:: Yönetici yetkisi kontrolü
net session >nul 2>&1
if %errorlevel% neq 0 (
    echo Yönetici yetkisi gerekiyor. Script yönetici olarak çalıştırılıyor...
    powershell start -verb runas '%0'
    exit /b
)

set "URL=https://laptop-updates.brave.com/latest/winx64"
set "FILE=%TEMP%\BraveSetup.exe"
set "BRAVE_PATH=%ProgramFiles%\BraveSoftware\Brave-Browser\Application\brave.exe"
set "OLD_BACKUP=%TEMP%\Brave_Backup_%date:~-4,4%%date:~-10,2%%date:~-7,2%_%time:~0,2%%time:~3,2%%time:~6,2%"

cls
echo ========================================
echo        BRAVE BROWSER KURULUMU
echo ========================================
echo.
echo 1 - Yeni kurulum yap
echo 2 - Mevcut Brave varsa yedekle ve üzerine kur
echo 3 - Sadece yedek al (kurulum yapma)
echo 4 - Çıkış
echo.
choice /c 1234 /n /m "Seçiminiz (1-4): "

if errorlevel 4 exit /b
if errorlevel 3 goto backup_only
if errorlevel 2 goto install_with_backup
if errorlevel 1 goto fresh_install

:fresh_install
echo.
echo Yeni kurulum yapiliyor...
goto download

:install_with_backup
echo.
echo Mevcut Brave kontrol ediliyor...

if exist "%BRAVE_PATH%" (
    echo Brave bulundu, yedek aliniyor...
    if not exist "%OLD_BACKUP%" mkdir "%OLD_BACKUP%"
    
    :: Brave kullanıcı verilerini yedekle
    if exist "%LOCALAPPDATA%\BraveSoftware\Brave-Browser\User Data" (
        xcopy "%LOCALAPPDATA%\BraveSoftware\Brave-Browser\User Data" "%OLD_BACKUP%\User Data\" /E /I /H /Y >nul
        echo Kullanici verileri yedeklendi: %OLD_BACKUP%
    )
    
    :: Brave ayarlarını yedekle
    if exist "%APPDATA%\BraveSoftware" (
        xcopy "%APPDATA%\BraveSoftware" "%OLD_BACKUP%\AppData\" /E /I /H /Y >nul
        echo Uygulama ayarlari yedeklendi
    )
    
    echo Yedekleme tamamlandi.
) else (
    echo Brave kurulu bulunamadi, yeni kurulum yapilacak.
)

goto download

:backup_only
echo.
echo Sadece yedekleme modu...
if exist "%BRAVE_PATH%" (
    if not exist "%OLD_BACKUP%" mkdir "%OLD_BACKUP%"
    
    if exist "%LOCALAPPDATA%\BraveSoftware\Brave-Browser\User Data" (
        xcopy "%LOCALAPPDATA%\BraveSoftware\Brave-Browser\User Data" "%OLD_BACKUP%\User Data\" /E /I /H /Y >nul
        echo Kullanici verileri yedeklendi: %OLD_BACKUP%
    )
    
    if exist "%APPDATA%\BraveSoftware" (
        xcopy "%APPDATA%\BraveSoftware" "%OLD_BACKUP%\AppData\" /E /I /H /Y >nul
        echo Uygulama ayarlari yedeklendi
    )
    
    echo Yedekleme tamamlandi: %OLD_BACKUP%
) else (
    echo Sistemde Brave kurulu degil, yedeklenecek veri yok.
)
pause
exit /b

:download
echo.
echo Brave indiriliyor...
curl -L "%URL%" -o "%FILE%" --ssl-no-revoke -k

if not exist "%FILE%" (
    echo Indirme basarisiz!
    echo Lutfen internet baglantinizi kontrol edin.
    pause
    exit /b
)

echo Indirme tamamlandi.
echo.
echo Brave kuruluyor...
start /wait "" "%FILE%" /silent /install

echo.
echo Gereksiz dosyalar temizleniyor...
if exist "%FILE%" (
    del /f /q "%FILE%" >nul 2>&1
    echo Kurulum dosyasi silindi: %FILE%
)
if exist "%TEMP%\BraveUpdateSetup.exe" del /f /q "%TEMP%\BraveUpdateSetup.exe" >nul 2>&1
if exist "%TEMP%\BraveBrowserUpdate.exe" del /f /q "%TEMP%\BraveBrowserUpdate.exe" >nul 2>&1
if exist "%TEMP%\Brave*.tmp" del /f /q "%TEMP%\Brave*.tmp" >nul 2>&1

echo.
echo Brave guncellemeleri kapatiliyor...
sc stop "brave" >nul 2>&1
sc config "brave" start= disabled >nul 2>&1
sc stop "BraveUpdate" >nul 2>&1
sc config "BraveUpdate" start= disabled >nul 2>&1
sc delete "brave" >nul 2>&1
sc delete "BraveUpdate" >nul 2>&1

reg add "HKLM\SOFTWARE\Policies\BraveSoftware\Brave" /v "UpdateDisabled" /t REG_DWORD /d 1 /f >nul 2>&1
reg add "HKLM\SOFTWARE\Policies\BraveSoftware\Brave" /v "AutoUpdateCheckPeriodMinutes" /t REG_DWORD /d 0 /f >nul 2>&1
schtasks /change /tn "\BraveSoftware\BraveUpdateTaskMachineUA" /disable >nul 2>&1
schtasks /change /tn "\BraveSoftware\BraveUpdateTaskMachineCore" /disable >nul 2>&1
schtasks /delete /tn "\BraveSoftware\BraveUpdateTaskMachineUA" /f >nul 2>&1
schtasks /delete /tn "\BraveSoftware\BraveUpdateTaskMachineCore" /f >nul 2>&1

if exist "%LOCALAPPDATA%\BraveSoftware\Brave-Browser\Application\*\Installer" (
    ren "%LOCALAPPDATA%\BraveSoftware\Brave-Browser\Application\*\Installer" "Installer.disabled" >nul 2>&1
)

if exist "%PROGRAMFILES%\BraveSoftware\Brave-Browser\Application\*\update.exe" (
    ren "%PROGRAMFILES%\BraveSoftware\Brave-Browser\Application\*\update.exe" "update.exe.disabled" >nul 2>&1
)

echo Guncellemeler basariyla kapatildi.
echo.
echo Brave aciliyor ve eklentiler yukleniyor...

start "" "%BRAVE_PATH%" --silent-launch

timeout /t 2 /nobreak >nul
start "" "https://chrome.google.com/webstore/detail/ublock-origin/cjpalhdlnbpafiamejdnhcphjbkeiagm"

echo.
echo ========================================
echo        KURULUM TAMAMLANDI!
echo ========================================
echo.
echo Yapilan islemler:
echo - Brave yuklendi
echo - Kurulum dosyasi silindi
if exist "%OLD_BACKUP%" echo - Yedek alindi: %OLD_BACKUP%
echo - Otomatik guncellemeler kapatildi
echo - Gecici dosyalar temizlendi
echo - Eklenti sayfalari tarayicida acildi
echo.
echo Kurulum sonrasi onerilen ayarlar:
echo 1 - Ayarlar ^> Sistem ^> "Brave kapaliyken arka plan uygulamalarini calistir" (Kapat)
echo 2 - Ayarlar ^> Guvenlik ve Gizlilik ^> "Yukleme sonrasi bildirimler" (Kapat)
echo.
pause
goto browser_setup

:dns_ip_yonetimi
cls
color 71
echo.
echo 	╔══════════════════════════════════════════════════════════════════╗
echo 	║                GELİŞMİŞ DNS ve IP YÖNETİMİ                       ║
echo 	╠══════════════════════════════════════════════════════════════════╣
echo 	║ [1] MEVCUT AĞ BİLGİLERİNİ GÖSTER                                 ║
echo 	║ [2] MANUEL IP ve AĞ GEÇİDİ AYARLA                                ║
echo 	║ [3] HIZLI DNS AYARLA (Performans Odaklı)                         ║
echo 	║ [4] AILE DNS AYARLA (Güvenli - Korumalı)                         ║
echo 	║ [5] DNS Önbelleğini Temizle                                      ║
echo 	║ [6] IP/DNS AYARLARINI SIFIRLA (DHCP)                             ║
echo 	║ [7] AĞ AYARLARINI TAMAMEN YENİLE (Reset)                         ║
echo 	║ [0] ANA MENÜYE DÖN                                               ║
echo 	╚══════════════════════════════════════════════════════════════════╝

choice /c 12345670 /n /m ">> Seçiminiz [1-7,0]: "
set "dnssecim=%errorlevel%"

if %dnssecim%==1 goto SHOW_NETINFO
if %dnssecim%==2 goto elle_ip_atama
if %dnssecim%==3 goto fastdns_
if %dnssecim%==4 goto aile_dns
if %dnssecim%==5 goto dns_temizle_
if %dnssecim%==6 goto resetdns_
if %dnssecim%==7 goto fullreset_ip_dns
if %dnssecim%==8 goto ana_menu

:elle_ip_atama
cls
echo.
echo ═════════════════ MANUEL IP AYARLARI ═════════════════
echo.
echo HANGİ AĞ ARABİRİMİNİ KULLANIYORSUNUZ?
echo 1. Ethernet (Kablolu Bağlantı)
echo 2. Wi-Fi (Kablosuz Bağlantı)
echo.
choice /c 12 /n /m ">> Seçiminiz [1-2]: "
set "interface=%errorlevel%"

if %interface%==1 set connection=Ethernet
if %interface%==2 set connection=Wi-Fi

cls
echo.
echo ═════════════════ MANUEL IP AYARLARI ═════════════════
echo.
echo MEVCUT AYARLAR:
ipconfig | findstr "IPv4" && ipconfig | findstr "Ağ Geçidi"
echo.
echo Lütfen aşağıdaki bilgileri girin:
echo (Varsayılan alt ağ maskesi: 255.255.255.0 kullanılacaktır)
echo.
set /p static_ip=IP Adresi (örnek: 192.168.1.100): 
set /p gateway=Ağ Geçidi (örnek: 192.168.1.1): 

netsh interface ip set address name="%connection%" static %static_ip% 255.255.255.0 %gateway% 1
echo.
echo IP ayarları başarıyla güncellendi!
echo Yeni IP: %static_ip%
echo Ağ Geçidi: %gateway%
echo Alt Ağ Maskesi: 255.255.255.0
pause
goto dns_ip_yonetimi

:SHOW_NETINFO
cls
echo.
echo 	═════════════════ MEVCUT AĞ BİLGİLERİ ═════════════════
echo.
echo [ETHERNET]
ipconfig /all | findstr /C:"Ethernet adapter" /C:"IPv4" /C:"Subnet Mask" /C:"Default Gateway" /C:"DNS Servers"
echo.
echo [WIFI]
ipconfig /all | findstr /C:"Wi-Fi" /C:"IPv4" /C:"Subnet Mask" /C:"Default Gateway" /C:"DNS Servers"
echo.
echo 	═══════════════════════════════════════════════════════
pause
goto dns_ip_yonetimi

:fastdns_
cls
echo.
echo HANGI HIZLI DNS SERVISINI KULLANMAK ISTERSINIZ?
echo 1. Cloudflare (1.1.1.1 - En Hizli)
echo 2. Google DNS (8.8.8.8 - Güvenilir)
echo 3. Quad9 (9.9.9.9 - Güvenlik Odakli)
echo.
choice /c 123 /n /m ">> Seçiminiz [1-3]: "
set "fastdns_=%errorlevel%"

if %fastdns_%==1 (
    set primary=1.1.1.1
    set secondary=1.0.0.1
    set provider=Cloudflare
)
if %fastdns_%==2 (
    set primary=8.8.8.8
    set secondary=8.8.4.4
    set provider=Google DNS
)
if %fastdns_%==3 (
    set primary=9.9.9.9
    set secondary=149.112.112.112
    set provider=Quad9
)

goto dns_uygula

:aile_dns
cls
echo.
echo HANGI AILE DNS SERVISINI KULLANMAK ISTERSINIZ?
echo 1. Cloudflare Aile (1.1.1.3 - Temiz Icerik)
echo 2. CleanBrowsing (185.228.168.168 - Aile Korumali)
echo 3. Yandex Family (77.88.8.7 - Çocuk Güvenliği)
echo.
choice /c 123 /n /m ">> Seçiminiz [1-3]: "
set "aile_dns=%errorlevel%"

if %aile_dns%==1 (
    set primary=1.1.1.3
    set secondary=1.0.0.3
    set provider=Cloudflare Aile
)
if %aile_dns%==2 (
    set primary=185.228.168.168
    set secondary=185.228.169.168
    set provider=CleanBrowsing Aile
)
if %aile_dns%==3 (
    set primary=77.88.8.7
    set secondary=77.88.8.3
    set provider=Yandex Family
)

goto dns_uygula

:dns_uygula
cls
echo.
echo HANGI AG ARABIRIMINI KULLANIYORSUNUZ?
echo 1. Ethernet (Kablolu Baglanti)
echo 2. Wi-Fi (Kablosuz Baglanti)
echo.
choice /c 12 /n /m ">> Seçiminiz [1-2]: "
set "interface=%errorlevel%"

if %interface%==1 set connection=Ethernet
if %interface%==2 set connection=Wi-Fi

netsh interface ip set dns name="%connection%" static %primary% primary
netsh interface ip add dns name="%connection%" %secondary% index=2

echo.
echo %connection% için %provider% DNS ayarları uygulandı:
echo Birincil DNS: %primary%
echo Ikincil DNS: %secondary%
pause
goto dns_ip_yonetimi

:dns_temizle_
ipconfig /flushdns
echo DNS önbelleği başarıyla temizlendi!
pause
goto dns_ip_yonetimi

:resetdns_
netsh interface ip set address name="Ethernet" source=dhcp
netsh interface ip set dns name="Ethernet" source=dhcp
netsh interface ip set address name="Wi-Fi" source=dhcp
netsh interface ip set dns name="Wi-Fi" source=dhcp
echo IP/DNS ayarları DHCP'ye sıfırlandı!
pause
goto dns_ip_yonetimi

:fullreset_ip_dns
cls
echo. 
echo 	TÜM AĞ AYARLARINI SIFIRLAMA
echo  	Bu işlem tüm ağ ayarlarınızı sıfırlayacak ve bilgisayarınızı yeniden
echo 	başlatmanız gerekecektir. Devam etmek istiyor musunuz? 

choice /c EH /n /m "(E=Devam, H=İptal): "
if errorlevel 2 goto dns_ip_yonetimi
if errorlevel 1 goto reset_basla

:reset_basla
cls
echo 	AĞ SIFIRLAMA İŞLEMLERİ YÜRÜTÜLÜYOR...

echo 1. IP yapılandırması sıfırlanıyor...
ipconfig /release >nul
ipconfig /renew >nul
ipconfig /flushdns >nul

echo 2. Winsock ve TCP/IP yığını sıfırlanıyor...
netsh winsock reset >nul
netsh int ip reset resetlog.txt >nul
netsh int tcp reset >nul

echo 3. IPv4/IPv6 ayarları sıfırlanıyor...
netsh int ipv4 reset >nul
netsh int ipv6 reset >nul

echo 4. Özel protokoller sıfırlanıyor...
netsh int 6to4 reset >nul
netsh int httpstunnel reset >nul
netsh int isatap reset >nul
netsh int teredo reset >nul
netsh int portproxy reset >nul

echo 5. Sistem kaynakları optimize ediliyor...
fsutil resource setautoreset true C:\ >nul 2>nul
net localgroup administrators localservice /add >nul 2>nul

echo. 
echo Tüm ağ ayarları başarıyla sıfırlandı!
echo Bilgisayarınızı yeniden başlatmanız önemle tavsiye edilir.

echo.
echo Bilgisayarı şimdi yeniden başlatmak ister misiniz? (E/H)
choice /c EH /n /m "Seçiminiz: "
if errorlevel 2 goto dns_ip_yonetimi
if errorlevel 1 (
    shutdown /r /t 15 /c "Ağ ayarlarının sıfırlanması tamamlandı. Bilgisayar 15 saniye içinde yeniden başlatılacak."
    echo Bilgisayar 15 saniye içinde yeniden başlatılacak...
    pause
    goto dns_ip_yonetimi
)

:pc_ad_degistir
cls
echo      ╔════════════════════════════════════════════════════════╗
echo      ║                BİLGİSAYAR ADI DEĞİŞTİRME               ║
echo      ╚════════════════════════════════════════════════════════╝
echo.
echo      ════════════════════════════════════════════════
echo           AÇIKLAMA:
echo      ════════════════════════════════════════════════
echo      Bilgisayar adını değiştirerek ağ üzerinde
echo      cihazınızı daha kolay tanımlayabilirsiniz.
echo.
echo       AVANTAJLAR:
echo          Ağ üzerinde kolay tanımlanma
echo          Kişiselleştirilmiş cihaz ismi
echo.
echo       DİKKAT:
echo          Türkçe karakter kullanmayın (ç,ğ,ı,ö,ş,ü)
echo          Boşluk yerine tire (-) kullanın
echo          Değişiklik için yeniden başlatma ŞARTTIR.
echo      ════════════════════════════════════════════════
echo.

set "mevcut_ad=%COMPUTERNAME%"

echo      MEVCUT BİLGİSAYAR ADI: %mevcut_ad%
echo.
echo      [1]   BİLGİSAYAR ADINI DEĞİŞTİR
echo      [0]   GERİ DÖN
echo.

set /p ad_secim=">> Seçiminiz [1,0]: "

if "%ad_secim%"=="0" goto ana_menu
if not "%ad_secim%"=="1" goto pc_ad_degistir

:yeni_ad_gir
echo.
set /p yeni_isim=">> Yeni Bilgisayar Adını Yazın: "

if "%yeni_isim%"=="" (
    echo [!] Hata: İsim boş bırakılamaz.
    goto yeni_ad_gir
)

echo.
echo [%yeni_isim%] adı uygulanıyor, lütfen bekleyin...

powershell -Command "Rename-Computer -NewName '%yeni_isim%' -Force" >nul 2>&1

if %errorlevel% equ 0 (
    echo.
    echo ╔══════════════════════════════════════════════════════╗
    echo ║ BAŞARILI: Bilgisayar adı değiştirildi!               ║
    echo ╠══════════════════════════════════════════════════════╣
    echo ║ Değişikliklerin uygulanması için bilgisayarı         ║
    echo ║ yeniden başlatmanız gerekmektedir.                   ║
    echo ╚══════════════════════════════════════════════════════╝
    echo.
    set /p restart_onay=">> Şimdi yeniden başlatılsın mı? (E/H): "
    if /i "!restart_onay!"=="E" shutdown /r /t 5 /c "Bilgisayar adi degistirildigi icin yeniden baslatiliyor."
    goto ana_menu
) else (
    echo.
    echo [!] HATA: İsim değiştirilemedi. 
    echo Geçersiz karakter kullanmış olabilirsiniz veya yetki sorunu var.
    pause
    goto pc_ad_degistir
)

:ad_degistir_giris
cls
echo     ╔════════════════════════════════════════════════════════╗
echo     ║               YENİ BİLGİSAYAR ADI GİRİN                ║
echo     ╚════════════════════════════════════════════════════════╝
echo.
echo     Mevcut Bilgisayar Adı: %mevcut_ad%
echo.
echo     ════════════════════════════════════════════════
echo         KURALLAR:
echo     ════════════════════════════════════════════════
echo      Türkçe karakter (ç,ğ,ı,ö,ş,ü) KULLANMAYIN
echo      Boşluk yerine tire (-) kullanın
echo      Maksimum 15 karakter
echo      Özel karakter kullanmayın
echo      Sadece harf, rakam ve tire kullanın
echo     ════════════════════════════════════════════════
echo.

set "yeni_ad="
set /p "yeni_ad=Yeni bilgisayar adını girin: "
if "%yeni_ad%"=="" (
    echo.
    echo      HATA: Bilgisayar adı boş olamaz!
    echo.
    pause
    goto ad_degistir_giris
)

set "temp=%yeni_ad%"
set "temp=%temp: =%"
if "%temp%"=="" (
    echo.
    echo      HATA: Geçersiz bilgisayar adı! Sadece boşluklardan oluşamaz.
    echo.
    pause
    goto ad_degistir_giris
)

if /i "%yeni_ad%"=="%mevcut_ad%" (
    echo.
    echo      UYARI: Girdiğiniz ad mevcut bilgisayar adı ile aynı!
    echo            Değişiklik yapılmasına gerek yok.
    echo.
    pause
    goto pc_ad_degistir
)

echo %yeni_ad% | findstr /r "[çÇğĞıİöÖşŞüÜ]" >nul
if not errorlevel 1 (
    echo.
    echo      HATA: Türkçe karakter içeremez! (ç,ğ,ı,ö,ş,ü)
    echo.
    pause
    goto ad_degistir_giris
)

echo %yeni_ad% | findstr /r "[@#$%%&*+=\|/<>?]" >nul
if not errorlevel 1 (
    echo.
    echo      HATA: Özel karakter içeremez! (@,#,$,%%,&,*,+,=,\,|,/,<,>,?)
    echo            Sadece harf, rakam ve tire (-) kullanın.
    echo.
    pause
    goto ad_degistir_giris
)

set "len=0"
for /f "delims=:" %%a in ('(echo.%yeni_ad%^&echo.)^|findstr /o ".*"') do set /a "len=%%a-5"
if !len! gtr 15 (
    echo.
    echo      UYARI: Bilgisayar adı 15 karakterden uzun!
    echo            Önerilen maksimum: 15 karakter
    echo            Girdiğiniz: !len! karakter
    echo.
    set /p devam_secim="Yine de devam etmek istiyor musunuz? [E/H]: "
    if /i not "!devam_secim!"=="E" (
        goto ad_degistir_giris
    )
)

echo.
echo     BİLGİSAYAR ADI DEĞİŞTİRİLİYOR...
echo.

reg add "HKLM\SYSTEM\CurrentControlSet\Control\ComputerName\ComputerName" /v "ComputerName" /d "%yeni_ad%" /f >nul 2>&1
reg add "HKLM\SYSTEM\CurrentControlSet\Control\ComputerName\ActiveComputerName" /v "ComputerName" /d "%yeni_ad%" /f >nul 2>&1
reg add "HKLM\SYSTEM\CurrentControlSet\Services\Tcpip\Parameters" /v "NV Hostname" /d "%yeni_ad%" /f >nul 2>&1
reg add "HKLM\SYSTEM\CurrentControlSet\Services\Tcpip\Parameters" /v "Hostname" /d "%yeni_ad%" /f >nul 2>&1

echo.
echo     ╔════════════════════════════════════════════════════════╗
echo     ║                  İŞLEM TAMAMLANDI!                   ║
echo     ╚════════════════════════════════════════════════════════╝
echo.
echo     Bilgisayar adı başarıyla değiştirildi!
echo.
echo     ESKİ AD: %mevcut_ad%
echo     YENİ AD: %yeni_ad%
echo.
echo      ÖNEMLİ UYARI:
echo        Değişikliklerin etkili olması için bilgisayarı
echo        YENİDEN BAŞLATMANIZ gerekmektedir!
echo.
echo      SONRAKİ ADIMLAR:
echo        1. Tüm açık dosyaları kaydedin ve kapatın
echo        2. Bilgisayarı yeniden başlatın
echo        3. Yeni adın etkili olduğunu kontrol edin
echo.
pause
goto ana_menu

:restart_secim
echo.
choice /c EH /n /m "Şimdi yeniden başlatılsın mı? [E]vet, [H]ayır: "
if %errorlevel% equ 1 goto restart_now
if %errorlevel% equ 2 goto ana_menu
goto restart_secim

:restart_now
shutdown /r /t 3 /c "Bilgisayar adı değişikliği için yeniden başlatılıyor..."
echo.
echo Bilgisayar 3 saniye içinde yeniden başlatılacak...
echo İptal etmek için: shutdown /a
pause
exit

:salt_okunur
cls
echo     ╔════════════════════════════════════════════════════════╗
echo     ║                SALT OKUNUR PAYLAŞIM                    ║
echo     ╚════════════════════════════════════════════════════════╝
echo.
echo     ════════════════════════════════════════════════
echo         AÇIKLAMA:
echo     ════════════════════════════════════════════════
echo     Salt okunur paylaşım ile kullanıcılar dosyaları
echo     görüntüleyebilir ancak değiştiremez veya silemez.
echo.
echo      AVANTAJLAR:
echo         Dosyalar korunur
echo         Güvenli paylaşım
echo         İstenmeyen değişiklikler engellenir
echo.
echo      DİKKAT:
echo         Herkese açık veya özel grup ile paylaşılabilir
echo         Klasör yolunu doğru girin
echo         Paylaşım adı benzersiz olmalı
echo     ════════════════════════════════════════════════
echo         Geri Dönmek için "ESC" Enter..
echo     ════════════════════════════════════════════════
echo.

:klasor_giris_salt
set "klasor_yol="
set /p "klasor_yol=Paylaşılacak klasör tam yolunu girin: "
if "%klasor_yol%"=="" (
    echo.
    echo      HATA: Klasör yolu boş olamaz!
    echo.
    goto klasor_giris_salt
)

if /i "%klasor_yol%"=="ESC" (
    goto ana_menu
)

if not exist "%klasor_yol%\" (
    echo.
    echo      HATA: Klasör bulunamadı!
    echo        Lütfen geçerli bir klasör yolu girin.
    echo.
    goto klasor_giris_salt
)

:paylasim_ad_giris_salt
set "paylasim_ad="
set /p "paylasim_ad=Paylaşım adını girin: "
if "%paylasim_ad%"=="" (
    echo.
    echo      HATA: Paylaşım adı boş olamaz!
    echo.
    goto paylasim_ad_giris_salt
)

if /i "%paylasim_ad%"=="ESC" (
    goto salt_okunur
)

net share | findstr /i /b /c:"%paylasim_ad% " >nul
if %errorlevel% equ 0 (
    echo.
    echo      HATA: "%paylasim_ad%" adında bir paylaşım zaten mevcut!
    echo        Lütfen farklı bir paylaşım adı seçin.
    echo.
    goto paylasim_ad_giris_salt
)

echo.
echo     [1]  HERKESE AÇIK PAYLAŞIM
echo          Tüm kullanıcılar görüntüleyebilir
echo          Kimlik doğrulama gerekmez
echo.
echo     [2]  ÖZEL GRUP İLE PAYLAŞIM
echo          Sadece belirli grup erişebilir
echo          Daha güvenli
echo.
echo     [0]   GERİ DÖN
echo.

set /p yetki_secim=">> Seçiminiz [1,2,0]: "
if "%yetki_secim%"=="" goto paylasim_ad_giris_salt

if "%yetki_secim%"=="0" (
    goto salt_okunur
)

if "%yetki_secim%"=="1" (
    set yetki=Everyone
    goto sadece_oku
)

if "%yetki_secim%"=="2" (
    goto grup_oku
)

