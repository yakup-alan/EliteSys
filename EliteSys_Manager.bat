goto :eof

:drivers_menu
cls
color 3F
echo.
echo        ╔══════════════════════════════════════════════════╗
echo        ║           GELİŞMİŞ SÜRÜCÜ YÖNETİMİ               ║
echo        ╠══════════════════════════════════════════════════╣
echo        ║ 1. Windows Sürücüleri Yedekle                    ║
echo        ║ 2. Windows Sürücüleri Geri Yükle                 ║
echo        ║ 3. GPU Bağlam Menülerini Onar                    ║
echo        ║ 4. Eksik Sürücüleri Tespit Et                    ║
echo        ║ 5. GPU Bağlam Menüde Sorun Olması Halinde        ║
echo        ║    Regedit Shell'den Komutu Silin.               ║
echo        ║ 0. Geri Ana Menü                                 ║
echo        ╚══════════════════════════════════════════════════╝
echo.
choice /c 123450 /n /m ">> Seçiminiz [1-5,0]: "
set "driverchoice=%errorlevel%"

if %driverchoice% equ 1 goto backup_drivers_only
if %driverchoice% equ 2 goto restore_drivers_only
if %driverchoice% equ 3 goto repair_gpu_context
if %driverchoice% equ 4 goto detect_missing
if %driverchoice% equ 5 goto regedit_shell
if %driverchoice% equ 6 goto ana_menu
goto drivers_menu

:regedit_shell
cls
color 1B
echo    Registry Editor Açılıyor ve Yol Gösteriliyor...
echo.

start regedit.exe

echo    REGISTRY YOLU:
echo    HKEY_CLASSES_ROOT\Directory\Background\shell
echo.
echo    ADIMLAR:
echo    1. Sol pencerede HKEY_CLASSES_ROOT'u tiklayin
echo    2. Directory klasörünü genişletin
echo    3. Background klasörünü genişletin  
echo    4. Shell klasörünü tıklayın
echo.
echo    BURADA GPU BAĞLAM MENULERINI BULABILIRSINIZ:
echo    - NVIDIA: NvGpu, NvCplDesktopContext
echo    - AMD: AmdGpu, ACE
echo    - Intel: IgfxCC, igfxcui
echo.
pause
goto drivers_menu

:repair_gpu_context
cls
echo.
echo        ╔══════════════════════════════════════════════════╗
echo        ║         GPU BAĞLAM MENÜLERİNİ ONAR               ║
echo        ╠══════════════════════════════════════════════════╣
echo        ║ Bu işlem sağ tık menüsündeki eksik GPU           ║
echo        ║ seçeneklerini (NVIDIA/AMD) onaracaktır.          ║
echo        ╚══════════════════════════════════════════════════╝
echo.

echo [!] GPU türü tespit ediliyor...
set "GPU_NAME="
for /f "usebackq delims=" %%G in (`powershell -NoProfile -Command "Get-WmiObject Win32_VideoController | Select-Object -ExpandProperty Name" 2^>nul`) do (
    set "GPU_NAME=%%G"
)

if not defined GPU_NAME (
    echo [X] GPU bilgisi alınamadı!
    pause
    goto drivers_menu
)

echo [i] Algılanan GPU: %GPU_NAME%
echo.

echo %GPU_NAME% | findstr /i "NVIDIA" >nul
if %errorlevel% equ 0 (
    echo [NVIDIA] Bağlam menüsü onarılıyor...
    call :repair_nvidia_context
) else (
    echo [i] NVIDIA GPU bulunamadı.
)
 
echo %GPU_NAME% | findstr /i "AMD" >nul
if %errorlevel% equ 0 (
    echo [AMD] Bağlam menüsü onarılıyor...
    call :repair_amd_context
) else (
    echo [i] AMD GPU bulunamadı.
)

echo.
echo [] GPU bağlam menüsü onarımı tamamlandı!
echo [!] Explorer yeniden başlatılıyor...
timeout /t 2 >nul
taskkill /f /im explorer.exe >nul 2>&1
start explorer.exe
echo [] Explorer yeniden başlatıldı.
echo.
echo  Sağ tık menüsünde GPU seçeneklerini kontrol edin.
pause
goto drivers_menu

:repair_nvidia_context
echo    [NVIDIA] Kayıt defteri ayarları yapılıyor...

reg add "HKCR\Directory\Background\shell\NvGpu" /v "MUIVerb" /d "NVIDIA Control Panel" /f >nul 2>&1
reg add "HKCR\Directory\Background\shell\NvGpu" /v "Icon" /d "nvcpl.dll,0" /f >nul 2>&1
reg add "HKCR\Directory\Background\shell\NvGpu" /v "SubCommands" /d "" /f >nul 2>&1
reg add "HKCR\Directory\Background\shell\NvGpu" /v "Position" /d "Top" /f >nul 2>&1

reg add "HKCR\Directory\Background\shell\NvGpu\shell\NvControlPanel" /v "MUIVerb" /d "NVIDIA Control Panel" /f >nul 2>&1
reg add "HKCR\Directory\Background\shell\NvGpu\shell\NvControlPanel" /v "Icon" /d "nvcpl.dll,0" /f >nul 2>&1
reg add "HKCR\Directory\Background\shell\NvGpu\shell\NvControlPanel\command" /ve /d "nvcplui.exe" /f >nul 2>&1

reg add "HKCR\Directory\Background\shell\NvGpu\shell\NvExperience" /v "MUIVerb" /d "NVIDIA GeForce Experience" /f >nul 2>&1
reg add "HKCR\Directory\Background\shell\NvGpu\shell\NvExperience" /v "Icon" /d "nvcpl.dll,1" /f >nul 2>&1
reg add "HKCR\Directory\Background\shell\NvGpu\shell\NvExperience\command" /ve /d "start geforce" /f >nul 2>&1

reg add "HKCR\Directory\Background\shellex\ContextMenuHandlers\NvCplDesktopContext" /ve /t REG_SZ /d "{3D1975AF-48C6-4f8e-A182-AC5012248AB5}" /f >nul 2>&1

reg add "HKCR\CLSID\{3D1975AF-48C6-4f8e-A182-AC5012248AB5}" /ve /t REG_SZ /d "NVIDIA Desktop Context Menu" /f >nul 2>&1
reg add "HKCR\CLSID\{3D1975AF-48C6-4f8e-A182-AC5012248AB5}\InProcServer32" /ve /t REG_SZ /d "C:\Windows\System32\nvshext.dll" /f >nul 2>&1
reg add "HKCR\CLSID\{3D1975AF-48C6-4f8e-A182-AC5012248AB5}\InProcServer32" /v "ThreadingModel" /t REG_SZ /d "Apartment" /f >nul 2>&1

echo    [NVIDIA] Bağlam menüsü kayıtları eklendi.
goto :eof

:repair_amd_context
echo    [AMD] Kayıt defteri ayarları yapılıyor...

reg add "HKCR\Directory\Background\shell\AmdGpu" /v "MUIVerb" /d "AMD Control Panel" /f >nul 2>&1
reg add "HKCR\Directory\Background\shell\AmdGpu" /v "Icon" /d "amdow.exe,0" /f >nul 2>&1
reg add "HKCR\Directory\Background\shell\AmdGpu" /v "SubCommands" /d "" /f >nul 2>&1
reg add "HKCR\Directory\Background\shell\AmdGpu" /v "Position" /d "Top" /f >nul 2>&1

reg add "HKCR\Directory\Background\shell\AmdGpu\shell\AmdControlPanel" /v "MUIVerb" /d "AMD Software: Adrenalin Edition" /f >nul 2>&1
reg add "HKCR\Directory\Background\shell\AmdGpu\shell\AmdControlPanel" /v "Icon" /d "amdow.exe,0" /f >nul 2>&1
reg add "HKCR\Directory\Background\shell\AmdGpu\shell\AmdControlPanel\command" /ve /d "amdow.exe" /f >nul 2>&1

reg add "HKCR\Directory\Background\shell\AmdGpu\shell\AmdSettings" /v "MUIVerb" /d "AMD Graphics Settings" /f >nul 2>&1
reg add "HKCR\Directory\Background\shell\AmdGpu\shell\AmdSettings" /v "Icon" /d "amdow.exe,1" /f >nul 2>&1
reg add "HKCR\Directory\Background\shell\AmdGpu\shell\AmdSettings\command" /ve /d "amd-settings:" /f >nul 2>&1

reg add "HKCR\Directory\Background\shellex\ContextMenuHandlers\ACE" /ve /t REG_SZ /d "{5E2121EE-0300-11D4-8D3B-444553540000}" /f >nul 2>&1

echo    [AMD] Bağlam menüsü kayıtları eklendi.
goto :eof

:install_gpu_tools
cls
echo.
echo        ╔══════════════════════════════════════════════════╗
echo        ║         GPU KONTROL PANELİ YÜKLEME               ║
echo        ╠══════════════════════════════════════════════════╣
echo        ║ Bu işlem GPU kontrol panelini ve bağlam          ║
echo        ║ menülerini yükleyecektir.                        ║
echo        ╚══════════════════════════════════════════════════╝
echo.

echo [!] GPU türü tespit ediliyor...
set "GPU_NAME="
for /f "usebackq delims=" %%G in (`powershell -NoProfile -Command "Get-WmiObject Win32_VideoController | Select-Object -ExpandProperty Name" 2^>nul`) do (
    set "GPU_NAME=%%G"
)

if not defined GPU_NAME (
    echo [X] GPU bilgisi alınamadı!
    pause
    goto drivers_menu
)

echo [i] Algılanan GPU: %GPU_NAME%
echo.

set "INSTALLED_NVIDIA=0"
set "INSTALLED_AMD=0"
set "INSTALLED_INTEL=0"

echo %GPU_NAME% | findstr /i "NVIDIA" >nul
if %errorlevel% equ 0 (
    echo [NVIDIA] Kontrol paneli yükleniyor...
    winget install -e --id Nvidia.GeForceExperience --accept-package-agreements --accept-source-agreements --silent >nul 2>&1
    if %errorlevel% equ 0 (
        echo    [] NVIDIA GeForce Experience yüklendi
        set "INSTALLED_NVIDIA=1"
        call :repair_nvidia_context
    ) else (
        echo    [X] NVIDIA GeForce Experience yüklenemedi
    )
)

echo %GPU_NAME% | findstr /i "AMD" >nul
if %errorlevel% equ 0 (
    echo [AMD] Kontrol paneli yükleniyor...
    winget install -e --id AdvancedMicroDevicesInc-2.AMDRadeonSoftware --accept-package-agreements --accept-source-agreements --silent >nul 2>&1
    if %errorlevel% equ 0 (
        echo    [] AMD Radeon Software yüklendi
        set "INSTALLED_AMD=1"
        call :repair_amd_context
    ) else (
        echo    [X] AMD Radeon Software yüklenemedi
    )
)

echo %GPU_NAME% | findstr /i "Intel" >nul
if %errorlevel% equ 0 (
    echo [Intel] Kontrol paneli yükleniyor...
    winget install -e --id 9PNMZNZ2JZXN --accept-package-agreements --accept-source-agreements --silent >nul 2>&1
    if %errorlevel% equ 0 (
        echo    [] Intel Graphics Command Center yüklendi
        set "INSTALLED_INTEL=1"
    ) else (
        echo    [X] Intel Graphics Command Center yüklenemedi
    )
)

echo.
echo [!] Explorer yeniden başlatılıyor...
timeout /t 2 >nul
taskkill /f /im explorer.exe >nul 2>&1
start explorer.exe

echo.
echo [] GPU kontrol paneli yükleme tamamlandı!
if %INSTALLED_NVIDIA% equ 1 echo    - NVIDIA bağlam menüsü eklendi
if %INSTALLED_AMD% equ 1 echo    - AMD bağlam menüsü eklendi
if %INSTALLED_INTEL% equ 1 echo    - Intel kontrol paneli eklendi
echo.
pause
goto drivers_menu

:backup_drivers_only
color 4A
cls
echo.
echo.
echo.
echo.
echo.
echo.
echo.
echo    		╔══════════════════════════════════════════╗
echo    		║         SÜRÜCÜ YEDEKLEME İŞLEMİ          ║
echo    		╠══════════════════════════════════════════╣
echo    		║ 1. Sürücüler taranıyor ve yedekleniyor...║
echo    		║    Bu işlem sisteminize göre uzun        ║
echo    		║    sürebilir, lütfen bekleyiniz...       ║
echo    		╚══════════════════════════════════════════╝
echo.
for /f %%A in ('powershell -Command "Get-Date -Format yyyy-MM-dd_HH-mm"') do set "TARIH=%%A"
set "BACKUP_DIR=%USERPROFILE%\Desktop\Sürücü_Yedek_%TARIH%"

echo [1/3] Sürücüler yedekleniyor...
powershell -Command "Export-WindowsDriver -Online -Destination '%BACKUP_DIR%'" >nul || (
    echo.
    echo [X] HATA: Sürücü yedekleme işlemi başarısız oldu!
    echo [!] Lütfen bu programı **yönetici olarak** çalıştırdığınızdan emin olun.
    pause
    goto drivers_menu
)
call :COUNT_DRIVERS "%BACKUP_DIR%"
echo [] Yedekleme tamamlandı: %BACKUP_DIR%
echo.

choice /c EH /n /m "[2/3] Yedek klasörünü ZIP dosyasına dönüştürmek istiyor musunuz? [E/H] "
if errorlevel 2 (
    echo.
    echo [] Yedek klasörü ZIP'e dönüştürülmedi: %BACKUP_DIR%
    pause
    goto drivers_menu
)
set "ZIP_FILE=%BACKUP_DIR%.zip"
cls
echo [3/3] ZIP dosyası oluşturuluyor, lütfen bekleyiniz...
echo.
echo.
echo.
echo.
echo.
echo.
echo.
echo    		╔══════════════════════════════════════════╗
echo    		║            ZIP OLUŞTURMA DURUMU          ║
echo    		╠══════════════════════════════════════════╣
echo    		║ - Boyut büyükse bu işlem uzun sürebilir  ║
echo    		║ - Program kilitlenmedi, üstte powershell ║
echo    		║   barından durumu takip edebilirsiniz... ║
echo    		╚══════════════════════════════════════════╝
echo.
powershell -Command "Compress-Archive -Path '%BACKUP_DIR%\*' -DestinationPath '%ZIP_FILE%' -Force" || (
    echo.
    echo [X] HATA: ZIP oluşturulamadı!
    pause
    goto drivers_menu
)
for %%Z in ("%ZIP_FILE%") do set ZIPSIZE=%%~zZ
set /a ZIPMB=%ZIPSIZE%/1024/1024
echo [] ZIP oluşturuldu: %ZIP_FILE%
echo [i] ZIP dosya boyutu: %ZIPMB% MB
echo.
echo [i] ZIP dosyasını masaüstünüzde şu konumda bulabilirsiniz:
echo     %ZIP_FILE%
echo.
choice /m "ZIP işleminden sonra yedek klasörünü silmek ister misiniz?"
if errorlevel 1 (
    rd /s /q "%BACKUP_DIR%"
    echo [] Yedek klasörü silindi
)
pause
goto drivers_menu

:COUNT_DRIVERS
set "count=0"
for /f %%A in ('dir /b /s /a-d "%~1\*.inf" 2^>nul ^| find /c /v ""') do set "count=%%A"
echo [] Toplam !count! Sürücü yedeklendi.
exit /b

:restore_drivers_only
Color 1A
cls
echo.
echo        	╔══════════════════════════════════════════════════╗
echo        	║           GELİŞMİŞ SÜRÜCÜ GERİ YÜKLEME           ║
echo        	╠══════════════════════════════════════════════════╣
echo        	║ Lütfen sürücü kaynağını seçin:                   ║
echo        	║ 1. Klasör (INF dosyaları)                        ║
echo        	║ 2. ZIP dosyası                                   ║
echo        	║ 0. Geri                                          ║
echo        	╚══════════════════════════════════════════════════╝
echo.
choice /c 120 /n /m ">> Seçiminiz [1,2,0]: "
set "restorechoice=%errorlevel%"

if %restorechoice% equ 1 goto select_folder
if %restorechoice% equ 2 goto select_zip
if %restorechoice% equ 3 goto drivers_menu
goto restore_drivers_only

:select_folder
set "RESTORE_PATH="
echo [!] Klasör seçim penceresi açılıyor...
echo [i] İptal etmek için "Cancel" butonuna tıklayın.

set "PWSH_SCRIPT=(New-Object -COM 'Shell.Application').BrowseForFolder(0,'Sürücü klasörünü seçin:',0x4000,0).Self.Path"
for /f "usebackq delims=" %%i in (`powershell -nologo -command "%PWSH_SCRIPT%" 2^>nul`) do set "RESTORE_PATH=%%i"

if not defined RESTORE_PATH (
    echo [i] Klasör seçimi iptal edildi veya hata oluştu.
    echo [i] Menüye geri dönülüyor...
    timeout /t 2 >nul
    goto restore_drivers_only
)

echo [] Klasör seçildi: %RESTORE_PATH%
goto start_restore

:select_zip
echo.
echo        	╔══════════════════════════════════════════════════╗
echo        	║               ZIP DOSYASI SEÇİMİ                 ║
echo        	╠══════════════════════════════════════════════════╣
echo        	║ Lütfen sürücü yedeklerinin bulunduğu             ║
echo        	║ ZIP dosyasını seçin...                           ║
echo        	╚══════════════════════════════════════════════════╝
echo.

:retry_zip_selection
set "ZIP_FILE="
set "EXTRACT_DIR="

set "PWSH_SCRIPT=Add-Type -AssemblyName System.Windows.Forms; $f = New-Object Windows.Forms.OpenFileDialog; $f.Title = 'Sürücü Yedek ZIP Dosyası Seçin'; $f.Filter = 'ZIP files (*.zip)|*.zip'; $f.Multiselect = $false; if($f.ShowDialog() -eq 'OK') { $f.FileName } else { 'CANCEL' }"
for /f "usebackq delims=" %%i in (`powershell -nologo -command "%PWSH_SCRIPT%"`) do set "ZIP_FILE=%%i"

if "%ZIP_FILE%"=="CANCEL" goto restore_drivers_only
if "%ZIP_FILE%"=="" goto retry_zip_selection

if not exist "%ZIP_FILE%" (
    echo [X] Dosya bulunamadı: %ZIP_FILE%
    pause
    goto retry_zip_selection
)

echo [] ZIP dosyası seçildi: %ZIP_FILE%
set "EXTRACT_DIR=%TEMP%\DriverRestore_%RANDOM%"

echo [!] ZIP dosyası açılıyor...
powershell -Command "Expand-Archive -Path '%ZIP_FILE%' -DestinationPath '%EXTRACT_DIR%' -Force" 2>nul

if errorlevel 1 (
    echo [X] ZIP dosyası açılamadı veya bozuk!
    if exist "%EXTRACT_DIR%" rd /s /q "%EXTRACT_DIR%" 2>nul
    pause
    goto retry_zip_selection
)

set "INF_FOUND=0"
for /r "%EXTRACT_DIR%" %%i in (*.inf) do set "INF_FOUND=1"

if %INF_FOUND% equ 0 (
    echo [X] ZIP dosyasında INF dosyası bulunamadı!
    rd /s /q "%EXTRACT_DIR%" 2>nul
    pause
    goto retry_zip_selection
)

set "RESTORE_PATH=%EXTRACT_DIR%"
echo [] ZIP başarıyla açıldı, INF dosyaları bulundu

:start_restore
if "%RESTORE_PATH%"=="" (
    echo [X] Geçerli bir yol seçilmedi.
    pause
    goto restore_drivers_only
)

set "FOUND_INF=0"
for /r "%RESTORE_PATH%" %%i in (*.inf) do (
    set "FOUND_INF=1"
    goto found_inf_files
)

if %FOUND_INF% equ 0 (
    echo [X] INF dosyası bulunamadı!
    if defined EXTRACT_DIR rd /s /q "%EXTRACT_DIR%"
    pause
    goto restore_drivers_only
)

:found_inf_files
echo [] INF dosyaları bulundu, yükleme başlıyor...
echo.

echo    İşlem sırasında bilgisayar otomatik olarak yeniden başlatılabilir.
echo    Lütfen açık dosyalarınızı kaydedin ve bir tuşa basın...
echo.
pause >nul

pnputil /add-driver "%RESTORE_PATH%\*.inf" /subdirs /install /reboot

echo.
echo [] İşlem tamamlandı!

if defined EXTRACT_DIR (
    echo [i] Geçici dosyalar temizleniyor...
    rd /s /q "%EXTRACT_DIR%"
)

echo.
echo [!] Eğer bilgisayar otomatik yeniden başlamazsa, elle yeniden başlatmanız gerekebilir.
pause
goto drivers_menu

:detect_missing
cls
color 75
echo.
echo    	***************************************
echo    	*       SURUCU SAGLIK KONTROLU       *
echo    	***************************************
echo.

echo    [1/3] Sürücü veritabanı taranıyor...
timeout /t 1 >nul

echo    [2/3] Donanım uyumluluğu kontrol ediliyor...
timeout /t 1 >nul

echo    [3/3] Sonuçlar değerlendiriliyor...
timeout /t 1 >nul
start devmgmt.msc
echo.
powershell -Command "$missing = Get-WindowsDriver -Online -All | Where-Object {$_.Inbox -eq $false -and $_.Driver -eq $null}; $total = (Get-WindowsDriver -Online -All | Where-Object {$_.Inbox -eq $false}).Count; if ($missing) { Write-Output 'SONUC: ' $missing.Count '/' $total ' SURUCU EKSIK'; Write-Output ''; Write-Output '--- EKSIK SURUCU LISTESI ---'; $missing | Format-Table Driver, Class, Date -AutoSize } else { Write-Output 'SONUC: 0/' $total ' SURUCU EKSIK - SISTEM SAGLIKLI'; Write-Output ''; Write-Output 'TÜM SÜRÜCÜLER BAŞARIYLA YÜKLENMİŞ' }"

echo.
echo    	***************************************
echo    	*            TAVSIYELER               *
echo    	***************************************
echo    	- Eksik driver varsa yedeklerinizden yükleyin
echo    	- Donanım üreticisi sitesini ziyaret edin  
echo    	- Windows Update'i çalıştırın
echo    	- Düzenli sürücü yedeği alın
echo.

pause
goto drivers_menu

:browser_setup
cls
color 75
ping -n 1 8.8.8.8 >nul 2>&1
if errorlevel 1 (
    echo.
    echo    ╔══════════════════════════════════════════════════╗
    echo    ║                                                  ║
    echo    ║   [HATA] İnternet bağlantınız yok veya bir       ║
    echo    ║   sorun var!                                     ║
    echo    ║                                                  ║
    echo    ╚══════════════════════════════════════════════════╝
    echo.
    pause
    exit /b
)

echo.
echo    		╔══════════════════════════════════════════════════╗
echo    		║            TARAYICI YÜKLEME ARACI                ║
echo    		╠══════════════════════════════════════════════════╣
