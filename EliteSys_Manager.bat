:sistem_optimizasyon
mode con: cols=82 lines=30
cls
echo.
echo    	╔══════════════════════════════════════════╗
echo    	║       SİSTEM OPTİMİZASYON AYARLARI       ║
echo    	╠══════════════════════════════════════════╣
echo    	║ 1. Reserved Storage (Ayrılmış Depolama)  ║
echo    	║ 2. Hibernation (Hazırda Bekletme)        ║
echo    	║ 3. Windows Sıkıştırma Ayarları           ║
echo    	║ 4. WinSxS Klasörü Temizleme (ResetBase)  ║
echo    	║                                          ║
echo    	║ 0. Ana Menüye Dön                        ║
echo    	╚══════════════════════════════════════════╝
echo.

choice /c 12340 /n /m ">> Seçiminiz [1-4,0]: "
set optimizasyon_secim=%errorlevel%

if %optimizasyon_secim% equ 1 goto reserved_storage
if %optimizasyon_secim% equ 2 goto hibernation_setting
if %optimizasyon_secim% equ 3 goto compact_windows
if %optimizasyon_secim% equ 4 goto clean_winsxs
if %optimizasyon_secim% equ 5 goto ana_menu
goto sistem_optimizasyon

:reserved_storage
cls
echo     ╔════════════════════════════════════════════════════════╗
echo     ║               AYRILMIŞ DEPOLAMA YÖNETİMİ               ║
echo     ╚════════════════════════════════════════════════════════╝
echo.
echo     ════════════════════════════════════════════════
echo         AÇIKLAMA:
echo     ════════════════════════════════════════════════
echo     Ayrılmış Depolama, Windows güncellemeleri için
echo     otomatik olarak ayrılmış disk alanıdır.
echo.
echo      Devre dışı bırakılırsa: ~7GB disk alanı kazanırsınız
echo      Ancak: Büyük Windows güncellemelerinde sorun yaşayabilirsiniz
echo.
echo     ════════════════════════════════════════════════
echo         MEVCUT DURUM:
echo     ════════════════════════════════════════════════
dism /Online /Get-ReservedStorageState
echo     ════════════════════════════════════════════════
echo.
echo     [1]  AYRILMIŞ DEPOLAMAYI DEVRE DIŞI BIRAK
echo          ~7GB disk alanı kazanır
echo          Güncelleme sorun riski
echo.
echo     [2]  AYRILMIŞ DEPOLAMAYI ETKİNLEŞTİR
echo          Windows güncellemeleri için güvenli
echo          ~7GB disk alanı kullanır
echo.
echo     [3]   GERİ DÖN
echo.

set /p storage_secim=">> Seçiminiz [1,2,3]: "
if "%storage_secim%"=="" goto reserved_storage

if "%storage_secim%"=="1" (
    cls
    echo.
    echo     AYRILMIŞ DEPOLAMA DEVRE DIŞI BIRAKILIYOR...
    echo.
    dism /Online /Set-ReservedStorageState /State:Disabled >nul
    echo      AYRILMIŞ DEPOLAMA DEVRE DIŞI BIRAKILDI!
    echo.
    echo     Yapılan değişiklik:
    echo         Ayrılmış depolama alanı kaldırıldı
    echo         ~7GB disk alanı kazanıldı
    echo.
    echo      UYARI: Büyük Windows güncellemelerinde
    echo            yetersiz alan hatası alabilirsiniz.
    echo.
    echo     Mevcut durum:
    dism /Online /Get-ReservedStorageState | find "State"
    echo.
    pause
    goto sistem_optimizasyon
)

if "%storage_secim%"=="2" (
    cls
    echo.
    echo     AYRILMIŞ DEPOLAMA ETKİNLEŞTİRİLİYOR...
    echo.
    dism /Online /Set-ReservedStorageState /State:Enabled >nul
    echo      AYRILMIŞ DEPOLAMA ETKİNLEŞTİRİLDİ!
    echo.
    echo     Yapılan değişiklik:
    echo         Ayrılmış depolama alanı etkinleştirildi
    echo         Windows güncellemeleri için güvenli alan ayrıldı
    echo.
    echo     Mevcut durum:
    dism /Online /Get-ReservedStorageState | find "State"
    echo.
    pause
    goto sistem_optimizasyon
)

if "%storage_secim%"=="3" (
    goto sistem_optimizasyon
)

goto reserved_storage

:hibernation_setting
cls
echo     ╔════════════════════════════════════════════════════════╗
echo     ║               HAZIRDA BEKLETME AYARLARI                ║
echo     ╚════════════════════════════════════════════════════════╝
echo.
echo     ════════════════════════════════════════════════
echo         AÇIKLAMA:
echo     ════════════════════════════════════════════════
echo     Hazırda Bekletme, bilgisayarınızın tamamen
echo     kapatılıp daha sonra kaldığınız yerden devam
echo     etmenizi sağlayan güç yönetimi özelliğidir.
echo.
echo      ETKİN: 
echo         Açık programlar ve dosyalar kaydedilir
echo         hiberfil.sys dosyası (~RAM boyutu kadar)
echo         Hızlı başlatma çalışır
echo.
echo      DEVRE DIŞI:
echo         hiberfil.sys dosyası silinir
echo         Hızlı başlatma çalışmaz
echo         ~RAM boyutu kadar disk alanı kazanılır
echo     ════════════════════════════════════════════════
echo         MEVCUT DURUM:
echo     ════════════════════════════════════════════════
powercfg /a
echo     ════════════════════════════════════════════════
echo.
echo     [1]  HAZIRDA BEKLETME'yi DEVRE DIŞI BIRAK
echo          hiberfil.sys dosyası silinir
echo          Disk alanı kazanırsınız
echo          Hızlı başlatma devre dışı kalır
echo.
echo     [2]  HAZIRDA BEKLETME'yi ETKİNLEŞTİR
echo          Açık oturumunuz kaydedilir
echo          Hızlı başlatma çalışır
echo          hiberfil.sys dosyası oluşturulur
echo.
echo     [3]   GERİ DÖN
echo.

set /p hiber_secim=">> Seçiminiz [1,2,3]: "
if "%hiber_secim%"=="" goto hibernation_setting

if "%hiber_secim%"=="1" (
    cls
    echo.
    echo     HAZIRDA BEKLETME DEVRE DIŞI BIRAKILIYOR...
    echo.
    powercfg -h off
    echo      HAZIRDA BEKLETME DEVRE DIŞI BIRAKILDI!
    echo.
    echo     Yapılan değişiklikler:
    echo         hiberfil.sys dosyası silindi
    echo         Hızlı başlatma devre dışı bırakıldı
    echo         Disk alanı kazanıldı
    echo.
    echo      NOT: Bilgisayarı tamamen kapatmak için
    echo           artık 'Tam kapatma' yapmanız gerekebilir.
    echo.
    echo     Mevcut durum:
    powercfg /a
    echo.
    pause
    goto hibernation_setting
)

if "%hiber_secim%"=="2" (
    cls
    echo.
    echo     HAZIRDA BEKLETME ETKİNLEŞTİRİLİYOR...
    echo.
    powercfg -h on
    echo      HAZIRDA BEKLETME ETKİNLEŞTİRİLDİ!
    echo.
    echo     Yapılan değişiklikler:
    echo         hiberfil.sys dosyası oluşturuldu
    echo         Hızlı başlatma etkinleştirildi
    echo         Açık oturum kaydetme özelliği aktif
    echo.
    echo     Mevcut durum:
    powercfg /a
    echo.
    pause
    goto hibernation_setting
)

if "%hiber_secim%"=="3" (
    goto sistem_optimizasyon
)

goto hibernation_setting

:compact_windows
cls
echo     ╔════════════════════════════════════════════════════════╗
echo     ║               WINDOWS SIKIŞTIRMA SİSTEMİ               ║
echo     ╚════════════════════════════════════════════════════════╝
echo.
echo     ════════════════════════════════════════════════
echo         AÇIKLAMA:
echo     ════════════════════════════════════════════════
echo     Windows Compact özelliği ile sistem dosyalarını
echo     sıkıştırırarak disk alanı kazanabilirsiniz.
echo.
echo      AVANTAJLAR:
echo         Disk alanı kazanırsınız
echo         Performans etkisi minimum
echo         Dosyalar normal kullanıma açık
echo.
echo      DEZAVANTAJLAR:
echo         İşlem uzun sürebilir
echo         Bazı uygulamalarda uyum sorunu
echo         CPU kullanımı artabilir
echo     ════════════════════════════════════════════════
echo.
echo     [1]  SİSTEM SIKIŞTIRMA UYGULA (XPRESS8K)
echo          Program Files ve Windows dizinleri
echo          Disk alanı kazanırsınız
echo          Uzun sürebilir
echo.
echo     [2]  SIKIŞTIRMAYI GERİ AL
echo          Tüm sıkıştırılmış dosyaları eski haline getirir
echo          Uyum sorunlarını çözer
echo.
echo     [3]  SIKIŞTIRMA DURUMUNU GÖSTER
echo          Mevcut sıkıştırma istatistikleri
echo          Hangi dosyaların sıkıştırıldığını gösterir
echo.
echo     [0]   GERİ DÖN
echo.

set /p compact_secim=">> Seçiminiz [1,2,3,0]: "
if "%compact_secim%"=="" goto compact_windows

if "%compact_secim%"=="1" goto compact_compress
if "%compact_secim%"=="2" goto compact_decompress
if "%compact_secim%"=="3" goto compact_status
if "%compact_secim%"=="0" goto sistem_optimizasyon

goto compact_windows

:compact_compress
cls
echo.
echo     SİSTEM SIKIŞTIRMA BAŞLATILIYOR...
echo.
echo      UYARI: Bu işlem 10-30 dakika sürebilir!
echo           Bilgisayarı kapatmayın veya yeniden başlatmayın.
echo.
echo     [1/4] Program Files sıkıştırılıyor...
compact /c /s /i /a /exe:XPRESS8K "C:\Program Files\*" >nul
echo         Program Files tamamlandı
echo     [2/4] Program Files (x86) sıkıştırılıyor...
compact /c /s /i /a /exe:XPRESS8K "C:\Program Files (x86)\*" >nul
echo         Program Files (x86) tamamlandı
echo     [3/4] Windows dizini sıkıştırılıyor...
compact /c /s /i /exe:XPRESS8K "C:\Windows\*" >nul
echo         Windows dizini tamamlandı
echo     [4/4] ProgramData sıkıştırılıyor...
compact /c /s /i /a /exe:XPRESS8K "C:\ProgramData\*" >nul
echo         ProgramData tamamlandı
echo.
echo      SİSTEM SIKIŞTIRMA TAMAMLANDI!
echo.
echo     Kazanılan alanı görmek için [3] seçeneğini kullanın.
echo.
pause
goto compact_windows

:compact_decompress
cls
echo.
echo     SIKIŞTIRMA GERİ ALINIYOR...
echo.
echo      NOT: Bu işlem birkaç dakika sürebilir.
echo.
echo     [1/4] Program Files geri alınıyor...
compact /u /s /i /a "C:\Program Files\*" >nul
echo         Program Files geri alındı
echo     [2/4] Program Files (x86) geri alınıyor...
compact /u /s /i /a "C:\Program Files (x86)\*" >nul
echo         Program Files (x86) geri alındı
echo     [3/4] Windows dizini geri alınıyor...
compact /u /s /i "C:\Windows\*" >nul
echo         Windows dizini geri alındı
echo     [4/4] ProgramData geri alınıyor...
compact /u /s /i /a "C:\ProgramData\*" >nul
echo         ProgramData geri alındı
echo.
echo      SIKIŞTIRMA GERİ ALINDI!
echo.
echo     Tüm dosyalar normal durumlarına döndürüldü.
echo.
pause
goto compact_windows

:compact_status
cls
echo.
echo     SIKIŞTIRMA DURUMU KONTROL EDİLİYOR...
echo.
echo     ════════════════════════════════════════════════
echo         SIKIŞTIRMA İSTATİSTİKLERİ:
echo     ════════════════════════════════════════════════
compact /q /s "C:\"
echo     ════════════════════════════════════════════════
echo.
echo     AÇIKLAMA:
echo      Toplam bayt: Tüm dosyaların boyutu
echo      Sıkıştırılmış bayt: Sıkıştırılmış dosyalar
echo      Oran: Ne kadar alan kazanıldığı
echo.
pause
goto compact_windows

:clean_winsxs
cls
echo     ╔════════════════════════════════════════════════════════╗
echo     ║               WINSXS KLASÖRÜ TEMİZLEME                 ║
echo     ╚════════════════════════════════════════════════════════╝
echo.
echo     ════════════════════════════════════════════════
echo         AÇIKLAMA:
echo     ════════════════════════════════════════════════
echo     WinSxS (Windows Side-by-Side) klasörü eski
echo     Windows güncelleme dosyalarını içerir.
echo.
echo      AVANTAJLAR:
echo         Disk alanı kazanırsınız (1-10GB)
echo         Eski güncelleme dosyaları temizlenir
echo         Sistem dosyaları optimize edilir
echo.
echo      DİKKAT:
echo         Bu işlem GERİ ALINAMAZ
echo         Eski Windows güncellemelerine dönemezsiniz
echo         İşlem 10-30 dakika sürebilir
echo         Sistem açık ve stabil olmalı
echo     ════════════════════════════════════════════════
echo.
echo     [1]   WINSXS TEMİZLEMEYİ BAŞLAT
echo          Eski güncelleme dosyaları silinir
echo          Disk alanı kazanılırsınız
echo          Geri alınamaz işlem
echo.
echo     [2]   GERİ DÖN
echo.

set /p winsxs_secim=">> Seçiminiz [1,2]: "
if "%winsxs_secim%"=="" goto clean_winsxs

if "%winsxs_secim%"=="2" (
    goto sistem_optimizasyon
)

if not "%winsxs_secim%"=="1" (
    goto clean_winsxs
)

cls
echo     ╔════════════════════════════════════════════════════════╗
echo     ║                   SON ONAY EKRANI                      ║
echo     ╚════════════════════════════════════════════════════════╝
echo.
echo      ÖNEMLİ UYARI 
echo.
echo     Bu işlem GERİ ALINAMAZ!
echo     Eski Windows güncellemelerini kaldıracaksınız.
echo.
echo     Devam etmek istiyor musunuz?
echo.
echo     [E] EVET, Devam Et
echo     [H] HAYIR, İptal Et
echo.

set /p son_onay=">> Seçiminiz [E/H]: "
if /i "%son_onay%"=="H" goto clean_winsxs
if /i not "%son_onay%"=="E" goto clean_winsxs

cls
echo.
echo     WINSXS TEMİZLEME BAŞLATILIYOR...
echo.
echo      Lütfen bekleyin, bu işlem 10-30 dakika sürebilir...
echo        Bilgisayarı kapatmayın veya yeniden başlatmayın!
echo.

echo     [1/4] Bileşen deposu analiz ediliyor...
DISM.exe /online /Cleanup-Image /AnalyzeComponentStore >nul
echo         Analiz tamamlandı

echo     [2/4] Bileşen temizliği başlatılıyor...
DISM.exe /online /Cleanup-Image /StartComponentCleanup >nul
echo         Bileşen temizliği tamamlandı

echo     [3/4] Eski servis paketleri temizleniyor...
DISM.exe /online /Cleanup-Image /SPSuperseded >nul
echo         Servis paketleri temizlendi

echo     [4/4] Temel temizlik uygulanıyor...
DISM.exe /online /Cleanup-Image /StartComponentCleanup /ResetBase
echo         Temel temizlik tamamlandı

if %errorlevel% equ 0 (
    echo.
    echo     ╔════════════════════════════════════════════════════════╗
    echo     ║                  İŞLEM BAŞARILI!                     ║
    echo     ╚════════════════════════════════════════════════════════╝
    echo.
    echo     WinSxS temizliği başarıyla tamamlandı!
    echo.
    echo     Kazanılan tahmini alan:
    for /f "tokens=3" %%a in ('DISM.exe /online /Cleanup-Image /AnalyzeComponentStore 2^>nul ^| find "Reclaimable"') do (
        echo         %%a
    )
    echo.
    echo      Eski güncelleme dosyaları temizlendi
    echo      Bileşen deposu optimize edildi
    echo      Disk alanı kazanıldı
    echo.
) else (
    echo.
    echo     ╔════════════════════════════════════════════════════════╗
    echo     ║                  İŞLEM BAŞARISIZ!                    ║
    echo     ╚════════════════════════════════════════════════════════╝
    echo.
    echo     WinSxS temizliği sırasında bir hata oluştu.
    echo.
    echo     Olası nedenler:
    echo         Yönetici hakları yetersiz
    echo         Sistem dosyaları bozuk
    echo         DISM servisi çalışmıyor
    echo.
)

pause
goto sistem_optimizasyon

:windows_up_setting
cls
echo     ╔════════════════════════════════════════════════════════╗
echo     ║              WINDOWS GÜNCELLEME YÖNETİMİ               ║
echo     ╚════════════════════════════════════════════════════════╝
echo.
echo     	  ════════════════════════════════════════════════
echo         	SEÇİM YAPINIZ:
echo     	  ════════════════════════════════════════════════
echo     		[1]   WINDOWS UPDATE TEMİZLİĞİ
echo         		 Güncelleme önbelleğini temizler
echo         		 Geçici dosyaları siler
echo         		 Hızlı çözüm
echo.
echo     		[2]  WINDOWS UPDATE SERVİSLERİNİ SIFIRLA
echo         		 Tüm servisleri yeniden başlatır
echo         		 Kayıt defterini temizler
echo         		 Kapsamlı çözüm
echo.
echo     		[3]   WINDOWS UPDATE DURDUR/BAŞLAT
echo         		 Güncelleme servislerini yönetir
echo         		 İnternet kullanımını kontrol eder
echo.
echo     		[4]   WINDOWS DOSYALARINI TARA ve ONAR
echo         		 Sistem dosyalarını kontrol eder
echo         		 Bozuk dosyaları onarır
echo.
echo     		[0]   ANA MENÜYE DÖN
echo.

set /p update_secim=">> Seçiminiz [1,2,3,4,0]: "
if "%update_secim%"=="" goto windows_up_setting

if "%update_secim%"=="1" goto update_temizleme
if "%update_secim%"=="2" goto update_servis_sifirla
if "%update_secim%"=="3" goto w_update_kontrol
if "%update_secim%"=="4" goto system_health
if "%update_secim%"=="0" goto ana_menu

goto windows_up_setting

:update_temizleme
cls
echo     ╔════════════════════════════════════════════════════════╗
echo     ║                WINDOWS UPDATE TEMİZLİĞİ                ║
echo     ╚════════════════════════════════════════════════════════╝
echo.
echo     Güncelleme önbelleği temizleniyor...
echo.
echo     [1/4] Güncelleme servisleri durduruluyor...
net stop wuauserv >nul 2>&1
net stop cryptSvc >nul 2>&1
net stop bits >nul 2>&1
net stop msiserver >nul 2>&1
echo         Servisler durduruldu

echo     [2/4] Önbellek dosyaları siliniyor...
del /q /f /s "%systemroot%\SoftwareDistribution\*.*" >nul 2>&1
del /q /f /s "%systemroot%\System32\catroot2\*.*" >nul 2>&1
echo         Önbellek temizlendi

echo     [3/4] Servisler yeniden başlatılıyor...
net start wuauserv >nul 2>&1
net start cryptSvc >nul 2>&1
net start bits >nul 2>&1
net start msiserver >nul 2>&1
echo         Servisler başlatıldı

echo     [4/4] DNS önbelleği temizleniyor...
ipconfig /flushdns >nul 2>&1
echo         DNS önbelleği temizlendi

echo.
echo      WINDOWS UPDATE TEMİZLİĞİ TAMAMLANDI!
echo.
echo     Yapılan işlemler:
echo         Güncelleme servisleri yeniden başlatıldı
echo         Önbellek dosyaları silindi
echo         DNS önbelleği temizlendi
echo.
echo     NOT: Windows Update'i şimdi kontrol edebilirsiniz.
echo.
pause
goto windows_up_setting

:update_servis_sifirla
cls
echo     ╔════════════════════════════════════════════════════════╗
echo     ║            WINDOWS UPDATE SERVİS SIFIRLAMA             ║
echo     ╚════════════════════════════════════════════════════════╝
echo.
echo     ════════════════════════════════════════════════
echo         AÇIKLAMA:
echo     ════════════════════════════════════════════════
echo     Bu işlem Windows Update servislerini tamamen
echo     sıfırlayarak güncelleme sorunlarını çözer.
echo.
echo      YAPILACAKLAR:
echo         Tüm güncelleme servisleri yeniden başlatılır
echo         Önbellek klasörleri yeniden oluşturulur
echo         Kayıt defteri ayarları temizlenir
echo.
echo      DİKKAT:
echo         İnternet bağlantısı gerektirir
echo         1-3 dakika sürebilir
echo         Windows Update geçmişi silinir
echo     ════════════════════════════════════════════════
echo.
echo     Devam etmek istiyor musunuz?
echo.
echo     [1] EVET, Sıfırlama İşlemini Başlat
echo     [0] HAYIR, Geri Dön
echo.

set /p reset_secim=">> Seçiminiz [1,0]: "
if "%reset_secim%"=="" goto update_servis_sifirla

if "%reset_secim%"=="0" (
    goto windows_up_setting
)

if not "%reset_secim%"=="1" (
    goto update_servis_sifirla
)

cls
echo.
echo     WINDOWS UPDATE SERVİS SIFIRLAMA BAŞLATILIYOR...
echo.
echo      Lütfen bekleyin, işlem devam ediyor...
echo.

echo     [1/5] Güncelleme servisleri durduruluyor...
net stop wuauserv >nul 2>&1
net stop cryptSvc >nul 2>&1
net stop bits >nul 2>&1
net stop msiserver >nul 2>&1
echo         Servisler durduruldu

echo     [2/5] Önbellek klasörleri yeniden adlandırılıyor...
ren "%systemroot%\SoftwareDistribution" "SoftwareDistribution.bak" >nul 2>&1
ren "%systemroot%\System32\catroot2" "catroot2.bak" >nul 2>&1
echo         Önbellek klasörleri yedeklendi

echo     [3/5] Kayıt defteri temizleniyor...
reg delete "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\WindowsUpdate" /v AccountDomainSid /f >nul 2>&1
reg delete "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\WindowsUpdate" /v PingID /f >nul 2>&1
reg delete "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\WindowsUpdate" /v SusClientId /f >nul 2>&1
reg delete "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\WindowsUpdate" /v SusClientIDValidation /f >nul 2>&1
echo         Kayıt defteri temizlendi

echo     [4/5] Servisler yeniden başlatılıyor...
net start wuauserv >nul 2>&1
net start cryptSvc >nul 2>&1
net start bits >nul 2>&1
net start msiserver >nul 2>&1
echo         Servisler başlatıldı

echo     [5/5] DNS ve komut istemci önbelleği temizleniyor...
ipconfig /flushdns >nul 2>&1
echo         Önbellekler temizlendi

echo.
echo      WINDOWS UPDATE SERVİS SIFIRLAMA TAMAMLANDI!
echo.
echo     Başarıyla tamamlanan işlemler:
echo         Güncelleme servisleri sıfırlandı
echo         Önbellek klasörleri yenilendi
echo         Kayıt defteri ayarları temizlendi
echo         DNS önbelleği temizlendi
echo.
echo     NOT: Windows'u yeniden başlatmanız önerilir.
echo          Ardından Windows Update'i kontrol edin.
echo.
pause
goto windows_up_setting

:w_update_kontrol
cls
echo.
echo    ╔══════════════════════════════════════════╗
echo    ║  WINDOWS UPDATE DURAKLATMA ARACI         ║
echo    ╠══════════════════════════════════════════╣
echo    ║  Geliştirici: Abdullah ERTÜRK            ║
echo    ╠══════════════════════════════════════════╣
echo    ║ 1. Güncellemeleri Duraklat               ║
echo    ║ 2. Güncellemeleri Devam Ettir            ║
echo    ║ 3. Windows Update Ayarlarını Aç          ║
echo    ║                                          ║
echo    ║ 0. Ana Menüye Geri Dön                   ║
echo    ╚══════════════════════════════════════════╝
echo.

choice /c 01234 /n /m ">> Seçiminiz [1-3,0]: "
set update_control_choice=%errorlevel%

if %update_control_choice% equ 2 goto pause_updates
if %update_control_choice% equ 3 goto resume_updates
if %update_control_choice% equ 4 goto open_settings
if %update_control_choice% equ 1 goto ana_menu
goto w_update_kontrol

:pause_updates
cls
set /p weeks="Duraklatma süresi (hafta olarak, örn: 4): "
if not defined weeks set weeks=4

(
echo Set objShell = CreateObject("WScript.Shell"^)
echo FlightSettingsMaxPauseDays = %weeks% * 7
echo objShell.RegWrite "HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\WindowsUpdate\UX\Settings\FlightSettingsMaxPauseDays", FlightSettingsMaxPauseDays, "REG_DWORD"
echo objShell.Run "cmd /c net stop wuauserv", 0, True
echo objShell.Run "cmd /c net start wuauserv", 0, True
echo MsgBox "Windows Guncellestirmeleri " ^& %weeks% ^& " hafta sureyle duraklatildi.", vbInformation, "Tebrikler"
)>"%temp%\wu_pause.vbs"
wscript "%temp%\wu_pause.vbs"
del "%temp%\wu_pause.vbs"
start ms-settings:windowsupdate
pause
goto w_update_kontrol

:resume_updates
cls
echo ========================================
echo    GÜNCELLEMELERİ DEVAM ETTİR
echo ========================================
echo [!] Güncelleme duraklatma ayarları sıfırlanıyor...
(
echo Set objShell = CreateObject("WScript.Shell"^)
echo objShell.RegDelete "HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\WindowsUpdate\UX\Settings\PauseFeatureUpdatesStartTime"
echo objShell.RegDelete "HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\WindowsUpdate\UX\Settings\PauseFeatureUpdatesEndTime"
echo objShell.RegDelete "HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\WindowsUpdate\UX\Settings\FlightSettingsMaxPauseDays"
echo objShell.Run "cmd /c net stop wuauserv", 0, True
echo objShell.Run "cmd /c net start wuauserv", 0, True
echo MsgBox "Windows Update duraklatma ayarlari sifirlandi.", vbInformation, "Tebrikler"
)>"%temp%\wu_resume.vbs"
wscript "%temp%\wu_resume.vbs"
del "%temp%\wu_resume.vbs"
start ms-settings:windowsupdate
pause
goto w_update_kontrol

:open_settings
start ms-settings:windowsupdate

:system_health
cls
echo     ╔════════════════════════════════════════════════════════╗
echo     ║                SİSTEM SAĞLIK KONTROLÜ                  ║
echo     ╚════════════════════════════════════════════════════════╝
echo.
echo     ════════════════════════════════════════════════
echo         AÇIKLAMA:
echo     ════════════════════════════════════════════════
echo     Bu araç Windows sistem dosyalarını kontrol eder
echo     ve bozuk dosyaları otomatik olarak onarır.
echo.
echo      YAPILACAK İŞLEMLER:
echo         Sistem görüntüsü sağlık kontrolü
echo         Bozuk dosya taraması
echo         Otomatik onarım
echo.
echo      DİKKAT:
echo         İşlem 15-45 dakika sürebilir
echo         İnternet bağlantısı gerekebilir
echo         Bilgisayarı kapatmayın
echo     ════════════════════════════════════════════════
echo.
echo     [1]  SİSTEM SAĞLIK KONTROLÜNÜ BAŞLAT
echo          Tüm sistem dosyaları taranır
echo          Bozuk dosyalar onarılır
echo          Uzun sürebilir
echo.
echo     [2]   GERİ DÖN
echo.

set /p health_secim=">> Seçiminiz [1,2]: "
if "%health_secim%"=="" goto system_health

if "%health_secim%"=="2" (
    goto ana_menu
)

if not "%health_secim%"=="1" (
    goto system_health
)

:start_system_health
cls
echo.
echo     SİSTEM SAĞLIK KONTROLÜ BAŞLATILIYOR...
echo.
echo      Yönetici hakları kontrol ediliyor...

REM Yönetici kontrolü
net session >nul 2>&1
if %errorlevel% neq 0 (
    echo      Yönetici hakları bulunamadı!
    echo.
    echo     Lütfen bu programı 'Yönetici olarak çalıştırın'.
    echo.
    pause
    goto system_health
)

echo      Yönetici hakları onaylandı
echo.
echo      İşlem başlatılıyor, lütfen bekleyin...
echo        Bu işlem 15-45 dakika sürebilir.
echo        Bilgisayarı kapatmayın veya yeniden başlatmayın!
