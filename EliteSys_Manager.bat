reg query "HKCU\Control Panel\Accessibility\Magnifier" /v "MagnifierHotkeysEnabled" >nul 2>&1
if %errorlevel% equ 0 (
    for /f "tokens=3" %%i in ('reg query "HKCU\Control Panel\Accessibility\Magnifier" /v "MagnifierHotkeysEnabled" 2^>nul') do (
        if "%%i"=="0x1" set "hotkeys=AKTİF"
    )
)

reg query "HKCU\Software\Microsoft\Windows\CurrentVersion\Policies\Explorer" /v "NoWinKeys" >nul 2>&1
if %errorlevel% equ 0 (
    for /f "tokens=3" %%i in ('reg query "HKCU\Software\Microsoft\Windows\CurrentVersion\Policies\Explorer" /v "NoWinKeys" 2^>nul') do (
        if "%%i"=="0x1" set "win_keys_policy=AKTİF (Engelli)"
