    shutdown /r /t 5
) else (
    goto ana_menu
)

:win_optimize_restore
cls
echo 	╔════════════════════════════════════════════════════════╗
echo 	║           VARSAYILAN AYARLAR GERI YUKLENIYOR           ║
echo 	╠════════════════════════════════════════════════════════╣
echo 	║ [] Geri dönüş işlemi başlatıldı.                      ║
