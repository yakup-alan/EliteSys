choice /c EH /n /m "İşlem başlatılsın mı? (E=EVET, H=HAYIR): "
if errorlevel 2 (
    echo [] İşlem iptal edildi...
    timeout /t 2 >nul
    goto ana_menu
)

echo.
echo [1/8] Mevcut yazıcı yapılandırması yedekleniyor...
set "desktop=%USERPROFILE%\Desktop"
set "backup_file=%desktop%\printer_backup_%date:~6,4%%date:~3,2%%date:~0,2%.reg"
reg export "HKLM\SYSTEM\CurrentControlSet\Control\Print" "%backup_file%" /y >nul 2>&1
reg export "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Print" "%backup_file%" /y >nul 2>&1

echo [2/8] Yazdırma hizmetleri güvenli şekilde durduruluyor...
net stop spooler >nul 2>&1
timeout /t 3 >nul
taskkill /F /IM splwow64.exe >nul 2>&1

echo [3/8] Yazdırma kuyruğu temizleniyor...
del /q /f /s "%systemroot%\System32\spool\PRINTERS\*.shd" >nul 2>&1
del /q /f /s "%systemroot%\System32\spool\PRINTERS\*.spl" >nul 2>&1

echo [4/8] Yazıcı sürücü önbelleği kontrol ediliyor...
rundll32 printui.dll,PrintUIEntry /Xs /n "Microsoft XPS Document Writer" attributes +direct >nul 2>&1

echo [5/8] Temel kayıt defteri ayarları güncelleniyor...
reg add "HKLM\SYSTEM\CurrentControlSet\Control\Print" /v "MajorVersion" /t REG_DWORD /d 4 /f >nul 2>&1
reg add "HKLM\SYSTEM\CurrentControlSet\Control\Print" /v "MinorVersion" /t REG_DWORD /d 3 /f >nul 2>&1

echo [6/8] Yazıcı hizmetleri yeniden yapılandırılıyor...
sc config spooler start= auto >nul 2>&1
sc config HTTP start= demand >nul 2>&1
net start spooler >nul 2>&1
timeout /t 5 >nul

echo [7/8] Ağ yazıcı ayarları optimize ediliyor...
reg add "HKLM\SYSTEM\CurrentControlSet\Control\Print" /v "DnsOnWire" /t REG_DWORD /d 1 /f >nul 2>&1

echo [8/8] Yazıcı hizmetleri yeniden başlatılıyor...
powershell -command "Restart-Service spooler" >nul 2>&1
timeout /t 2 >nul

echo.
echo ╔════════════════════════════════════════════════════════╗
echo ║       YAZICI ONARIM İŞLEMLERİ BAŞARIYLA TAMAMLANDI     ║
echo ╠════════════════════════════════════════════════════════╣
echo ║ [] Yazıcı yapılandırması yedeklendi:                  ║
echo ║     %backup_file%                                      ║
echo ║ [] Yazdırma hizmetleri güvenle yeniden başlatıldı     ║
echo ║ [] Temel sistem ayarları optimize edildi              ║
echo ║                                                        ║
echo ║ [!] Yazıcılarınızda hâlâ sorun varsa manuel kontrol    ║
echo ║     yapabilirsiniz                                     ║
echo ╚════════════════════════════════════════════════════════╝

echo.
choice /c EH /n /m "Bilgisayarı yeniden başlatmak ister misiniz? (Önerilir) (E/H): "
if errorlevel 2 (
    echo [] İşlem tamamlandı. Yazıcılarınızı manuel kontrol edin.
    pause
    exit /b
) else (
    echo [] Bilgisayar 15 saniye içinde yeniden başlatılacak...
    shutdown /r /t 15/c "Yazıcı onarım işlemleri tamamlandı. Lütfen yazıcılarınızı yeniden kontrol edin."
    pause
    exit
)

