    echo    ╔══════════════════════════════════════════╗
    echo    ║         HATA: Grup adı boş!              ║
    echo    ╚══════════════════════════════════════════╝
    goto sil_grup_giris
)

for %%g in (Administrators Users Guests) do (
    if /i "!sil_grup!"=="%%g" (
        echo    ╔══════════════════════════════════════════╗
        echo    ║   HATA: Sistem grubu silinemez: %%g      ║
        echo    ╚══════════════════════════════════════════╝
        pause
        goto sil_grup
    )
)

net localgroup | find /i "!sil_grup!" >nul
if %errorlevel% neq 0 (
    echo    ╔══════════════════════════════════════════╗
    echo    ║   HATA: "%sil_grup%" grubu yok!          ║
    echo    ╚══════════════════════════════════════════╝
    pause
    goto sil_grup_giris
)

net localgroup "!sil_grup!" /delete >nul
if %errorlevel% equ 0 (
    echo    ╔══════════════════════════════════════════╗
    echo    ║  BAŞARILI: "%sil_grup%" silindi!         ║
    echo    ╚══════════════════════════════════════════╝
) else (
    echo    ╔══════════════════════════════════════════╗
    echo    ║   HATA: Silme işlemi başarısız!          ║
    echo    ╚══════════════════════════════════════════╝
)
pause
goto paylasim_yonetimi

:paylasim_duzelt
cls
echo ============================================================
echo        [ PAYLASIM SORUNLARINI DUZELTME ]
echo ============================================================
echo.
echo Bu islem Windows dosya paylasimi icin gerekli servisleri,
echo guvenlik duvari kurallarini ve ag kesfi ayarlarini duzenler.
echo.
echo Varsayilan guvenli mod:
echo - Duz metin sifre kapali
echo - SMB imzalama etkin
echo - Guvensiz konuk erisimi kapali
echo - Firewall sadece Private ve Domain profillerinde acilir
echo.
echo [1] Guvenli paylasim duzeltmesi uygula
echo [2] Eski cihaz uyumlulugu ile uygula
echo     DIKKAT: Guvensiz konuk erisimi acilir
echo [3] Geri don
echo.

choice /c 123 /n /m ">> Seciminiz [1,2,3]: "

if errorlevel 3 goto ana_menu
if errorlevel 2 set "INSECURE_GUEST=1"
if errorlevel 1 if not defined INSECURE_GUEST set "INSECURE_GUEST=0"

cls
echo.
echo Paylasim ayarlari duzenleniyor...
echo.

echo [1/4] Registry ayarlari yapiliyor...
reg add "HKLM\SYSTEM\CurrentControlSet\Services\LanmanWorkstation\Parameters" /v "EnablePlainTextPassword" /t REG_DWORD /d 0 /f >nul 2>&1
reg add "HKLM\SYSTEM\CurrentControlSet\Services\LanmanWorkstation\Parameters" /v "EnableSecuritySignature" /t REG_DWORD /d 1 /f >nul 2>&1
reg add "HKLM\SYSTEM\CurrentControlSet\Services\LanmanWorkstation\Parameters" /v "RequireSecuritySignature" /t REG_DWORD /d 0 /f >nul 2>&1
reg add "HKLM\SYSTEM\CurrentControlSet\Services\LanmanWorkstation\Parameters" /v "AllowInsecureGuestAuth" /t REG_DWORD /d %INSECURE_GUEST% /f >nul 2>&1
echo Registry ayarlari tamamlandi.

echo.
echo [2/4] Servisler kontrol ediliyor...
sc config LanmanServer start= auto >nul 2>&1
sc config LanmanWorkstation start= auto >nul 2>&1
net start LanmanServer >nul 2>&1
net start LanmanWorkstation >nul 2>&1
echo Servisler tamamlandi.

echo.
echo [3/4] Guvenlik duvari kurallari aciliyor...
netsh advfirewall firewall set rule group="Network Discovery" new enable=yes profile=private,domain >nul 2>&1
netsh advfirewall firewall set rule group="File and Printer Sharing" new enable=yes profile=private,domain >nul 2>&1

netsh advfirewall firewall add rule name="EliteSys SMB In" dir=in action=allow protocol=TCP localport=445 enable=yes profile=private,domain >nul 2>&1
netsh advfirewall firewall add rule name="EliteSys NB Session In" dir=in action=allow protocol=TCP localport=139 enable=yes profile=private,domain >nul 2>&1
echo Guvenlik duvari tamamlandi.

echo.
echo [4/4] Ag profili bilgisi:
powershell -NoProfile -Command "Get-NetConnectionProfile | Select-Object Name,NetworkCategory"

echo.
echo ============================================================
echo Islem tamamlandi.
echo.
if "%INSECURE_GUEST%"=="1" (
    echo DIKKAT: Guvensiz konuk erisimi acildi.
    echo Eski cihazlarla isiniz bittikten sonra kapatmaniz onerilir.
) else (
    echo Guvenli mod uygulandi. Guvensiz konuk erisimi kapali.
)
echo.
echo Bilgisayari yeniden baslatmaniz onerilir.
echo ============================================================
pause
goto ana_menu

:restart_secim_paylasim
echo.
choice /c EH /n /m "Şimdi yeniden başlatılsın mı? [E]vet, [H]ayır: "
if %errorlevel% equ 1 (
    shutdown /r /t 15 /c "Paylaşım ayarları için yeniden başlatılıyor..."
    echo.
    echo Bilgisayar 15 saniye içinde yeniden başlatılacak...
    echo İptal etmek için: shutdown /a
)
pause

:geri_yukleme_menu
cls
echo.
echo    		╔══════════════════════════════════════════╗
echo    		║    SİSTEM GERİ YÜKLEME NOKTASI YÖNETİMİ  ║
echo    		╠══════════════════════════════════════════╣
echo    		║ 1. Yeni Geri Yükleme Noktası Oluştur     ║
echo    		║ 2. Mevcut Geri Yükleme Noktalarını Listele
echo    		║ 3. Geri Yükleme Noktası Sil              ║
echo    		║ 4. Tüm Geri Yükleme Noktalarını Sil      ║
echo    		╠══════════════════════════════════════════╣
echo    		║ 0. Ana Menüye Dön                        ║
echo    		╚══════════════════════════════════════════╝
echo.

choice /c 12340 /n /m ">> Seçiminiz [1-4,0]: "
set geri_secim=%errorlevel%

if %geri_secim% equ 1 goto rp_noktasi_olustur
if %geri_secim% equ 2 goto rp_noktasi_listele
if %geri_secim% equ 3 goto rp_noktasi_sil
if %geri_secim% equ 4 goto rp_toplu_sil
if %geri_secim% equ 5 goto ana_menu
goto geri_yukleme_menu

:rp_noktasi_olustur
cls
echo    		╔══════════════════════════════════════════╗
echo    		║     YENİ GERİ YÜKLEME NOKTASI OLUŞTUR    ║
echo    		╚══════════════════════════════════════════╝
echo.

reg query "HKLM\SOFTWARE\Microsoft\Windows NT\CurrentVersion\SystemRestore" /v "RPSessionInterval" >nul 2>&1
if %errorlevel% neq 0 (
    echo    	╔══════════════════════════════════════════╗
    echo    	║  HATA: Sistem Geri Yükleme devre dışı!   ║
    echo    	╠══════════════════════════════════════════╣
    echo    	║ 1. Sistem Geri Yükleme'yi Etkinleştir    ║
    echo    	║ 2. Sistem Ayarlarına Git                 ║
    echo    	╠══════════════════════════════════════════╣
    echo    	║ 0. Ana Menüye Dön                        ║
    echo    	╚══════════════════════════════════════════╝
    
    choice /c 120 /n /m ">> Seçiminiz [1,2,0]: "
    if %errorlevel% equ 1 (
        powershell -Command "Enable-ComputerRestore -Drive 'C:\'; Checkpoint-Computer -Description 'AwenGers44 Tarafından Etkinleştirildi'"
        goto geri_yukleme_menu
    )
    if %errorlevel% equ 2 (
        SystemPropertiesProtection.exe
        goto geri_yukleme_menu
    )
    if %errorlevel% equ 3 goto ana_menu
    goto geri_yukleme_menu
)

echo    ╔══════════════════════════════════════════╗
echo    ║  DİKKAT: Sistem durumu kaydedilecek!     ║
echo    ╚══════════════════════════════════════════╝
echo.

:rp_aciklama_al
set "aciklama="
set /p "aciklama=>> Geri yükleme noktası açıklaması (Geri: ESC): "
if /i "!aciklama!"=="ESC" goto ana_menu
if "!aciklama!"=="" (
    echo    ╔══════════════════════════════════════════╗
    echo    ║        HATA: Açıklama boş olamaz!        ║
    echo    ╚══════════════════════════════════════════╝
    goto rp_aciklama_al
)

echo    ╔══════════════════════════════════════════╗
echo    ║  Geri yükleme noktası oluşturuluyor...   ║
echo    ║  Lütfen bekleyin...                      ║
echo    ╚══════════════════════════════════════════╝

powershell -Command "try { Checkpoint-Computer -Description \"%aciklama%\" -ErrorAction Stop } catch { exit 1 }"
if %errorlevel% equ 0 (
    echo    ╔══════════════════════════════════════════╗
    echo    ║ BAŞARILI: Geri yükleme noktası oluşturuldu! 
    echo    ╚══════════════════════════════════════════╝
) else (
    echo    ╔══════════════════════════════════════════╗
    echo    ║  HATA: Geri yükleme noktası oluşturulamadı 
    echo    ╠══════════════════════════════════════════╣
    echo    ║ Olası nedenler:                          ║
    echo    ║ - Sistem Geri Yükleme devre dışı         ║
    echo    ║ - Yönetici hakları eksik                 ║
    echo    ║ - Yetersiz disk alanı                    ║
    echo    ║ - Güvenlik yazılımı engeli               ║
    echo    ╚══════════════════════════════════════════╝
)
pause
goto geri_yukleme_menu

:rp_noktasi_listele
cls
echo    ╔══════════════════════════════════════════╗
echo    ║     MEVCUT GERİ YÜKLEME NOKTALARI        ║
echo    ╚══════════════════════════════════════════╝
echo.

powershell -Command "& {try { $restorePoints = Get-ComputerRestorePoint | Select-Object SequenceNumber, Description, CreationTime; if ($restorePoints) { $restorePoints | Format-Table -AutoSize } else { Write-Output 'Hiç geri yükleme noktası bulunamadı.' } } catch { Write-Output 'HATA: Geri yükleme noktaları listelenirken bir sorun oluştu.' } }"

if %errorlevel% equ 1 (
    echo    ╔══════════════════════════════════════════╗
    echo    ║  UYARI: Geri yükleme noktası bulunamadı  ║
    echo    ╚══════════════════════════════════════════╝
)
pause
goto geri_yukleme_menu

:rp_noktasi_sil
cls
echo    ╔══════════════════════════════════════════╗
echo    ║       GERİ YÜKLEME NOKTASI SİLME         ║
echo    ╠══════════════════════════════════════════╣
echo    ║ DİKKAT: Bu işlem KALICIDIR!              ║
echo    ╚══════════════════════════════════════════╝
echo.

powershell -Command "if ((Get-ComputerRestorePoint).Count -eq 0) { exit 1 } else { exit 0 }"
if %errorlevel% neq 0 (
    echo    ╔══════════════════════════════════════════╗
    echo    ║  UYARI: Geri yükleme noktası bulunamadı  ║
    echo    ╚══════════════════════════════════════════╝
    pause
    goto geri_yukleme_menu
)

echo    ╔══════════════════════════════════════════╗
echo    ║   MEVCUT GERİ YÜKLEME NOKTALARI:         ║
echo    ╚══════════════════════════════════════════╝
powershell -Command "Get-ComputerRestorePoint | Select-Object SequenceNumber, Description, CreationTime | Format-Table -AutoSize"

:rp_sil_desc
echo.
set "desc="
set /p "desc=>> Silinecek noktanın AÇIKLAMASI (Geri: ESC): "
if /i "!desc!"=="ESC" goto geri_yukleme_menu
if "!desc!"=="" (
    echo    ╔══════════════════════════════════════════╗
    echo    ║        HATA: Açıklama boş olamaz!        ║
    echo    ╚══════════════════════════════════════════╝
    goto rp_sil_desc
)

for /f "tokens=* usebackq" %%s in (`powershell -Command "$rp = Get-ComputerRestorePoint | Where-Object { $_.Description -eq '%desc%' } | Select-Object -First 1; if ($rp) { $rp.SequenceNumber } else { exit 1 }"`) do (
    set "seq=%%s"
)

if not defined seq (
    echo    ╔══════════════════════════════════════════╗
    echo    ║  HATA: Eşleşen geri yükleme noktası yok  ║
    echo    ╚══════════════════════════════════════════╝
    pause
    goto rp_sil_desc
)

echo    ╔══════════════════════════════════════════╗
echo    ║  Geri yükleme noktası siliniyor...       ║
echo    ╚══════════════════════════════════════════╝

powershell -Command "vssadmin delete shadows /shadow={%seq%} /quiet"
if %errorlevel% equ 0 (
    echo    ╔══════════════════════════════════════════╗
    echo    ║  BAŞARILI: Geri yükleme noktası silindi  ║
    echo    ╚══════════════════════════════════════════╝
) else (
    echo    ╔══════════════════════════════════════════╗
    echo    ║  HATA: vssadmin ile silme başarısız      ║
    echo    ╠══════════════════════════════════════════╣
    echo    ║  Alternatif yöntem deneniyor...          ║
    echo    ╚══════════════════════════════════════════╝
    
    powershell -Command "Remove-ComputerRestorePoint -SequenceNumber %seq%"
    if %errorlevel% equ 0 (
        echo    ╔══════════════════════════════════════════╗
        echo    ║  BAŞARILI: Alternatif yöntemle silindi   ║
        echo    ╚══════════════════════════════════════════╝
    ) else (
        echo    ╔══════════════════════════════════════════╗
        echo    ║  HATA: Silme işlemi tamamen başarısız    ║
        echo    ╚══════════════════════════════════════════╝
    )
)

pause
goto geri_yukleme_menu

:rp_toplu_sil
cls
echo    ╔══════════════════════════════════════════╗
echo    ║   TOPLU GERİ YÜKLEME NOKTASI SİLME       ║
echo    ╠══════════════════════════════════════════╣
echo    ║ DİKKAT: Tüm noktalar KALICI olarak silinecek! 
echo    ║ Bu işlem GERİ ALINAMAZ!                  ║
echo    ╚══════════════════════════════════════════╝
echo.

echo    ╔══════════════════════════════════════════╗
echo    ║   MEVCUT GERİ YÜKLEME NOKTALARI:         ║
echo    ╚══════════════════════════════════════════╝
powershell -Command "Get-ComputerRestorePoint | Select-Object SequenceNumber, Description, CreationTime | Format-Table -AutoSize"

:onay_al
echo.
set "secim="
set /p "secim=>> Devam etmek istiyor musunuz? [E/ESC]: "
if /i "!secim!"=="ESC" goto geri_yukleme_menu
if /i not "!secim!"=="E" (
    echo    ╔══════════════════════════════════════════╗
    echo    ║        HATA: Geçersiz seçim!             ║
    echo    ╚══════════════════════════════════════════╝
    goto onay_al
)

cls
echo    ╔══════════════════════════════════════════╗
echo    ║  1. Adım: Tüm geri yükleme noktaları siliniyor... 
echo    ╚══════════════════════════════════════════╝
vssadmin delete shadows /for=C: /all
echo.
echo    ╔══════════════════════════════════════════╗
echo    ║  2. Adım: Alternatif silme yöntemi...    ║
echo    ╚══════════════════════════════════════════╝
powershell -Command "Get-ComputerRestorePoint | ForEach-Object { Remove-ComputerRestorePoint -RestorePoint $_.SequenceNumber }"
echo.
echo    ╔══════════════════════════════════════════╗
echo    ║  3. Adım: Disk temizleme işlemi...       ║
echo    ╚══════════════════════════════════════════╝
cleanmgr /sageset:65535 >nul
cleanmgr /sagerun:65535 >nul
echo.
echo    ╔══════════════════════════════════════════╗
echo    ║  Tüm işlemler başarıyla tamamlandı!      ║
echo    ╚══════════════════════════════════════════╝
pause
goto geri_yukleme_menu

:sifre_yonetimi
cls
echo.
echo    ╔══════════════════════════════════════════╗
echo    ║        KULLANICI ŞİFRE YÖNETİMİ          ║
echo    ╠══════════════════════════════════════════╣
echo    ║ 1. Kullanıcı Listesi Görüntüle           ║
echo    ║ 2. Kullanıcı Şifresi Oluştur/Değiştir    ║
echo    ║ 3. Kullanıcı Şifresini Kaldır            ║
echo    ║                                          ║
echo    ║ 0. Ana Menüye Dön                        ║
echo    ╚══════════════════════════════════════════╝
echo.

choice /c 1230 /n /m ">> Seçiminiz [1-3,0]: "
set sifre_secim=%errorlevel%

if %sifre_secim% equ 1 goto kullanici_listesi
if %sifre_secim% equ 2 goto sifre_olustur
if %sifre_secim% equ 3 goto sifre_kaldir
if %sifre_secim% equ 4 goto ana_menu
goto sifre_yonetimi

:kullanici_listesi
cls
echo    ╔══════════════════════════════════════════╗
echo    ║        YEREL KULLANICI LİSTESİ           ║
echo    ╚══════════════════════════════════════════╝
echo.
net user | findstr /v /c:"Komut başarıyla" | findstr /v /c:"\\" | findstr /v /c:"-----"
echo.
pause
goto sifre_yonetimi

:sifre_olustur
cls
echo    ╔══════════════════════════════════════════╗
echo    ║     KULLANICI ŞİFRESİ OLUŞTUR/DEĞİŞTİR   ║
echo    ╠══════════════════════════════════════════╣
echo    ║ DİKKAT: Şifre karmaşıklık kurallarına    ║
echo    ║ uymalıdır! (Büyük/küçük harf, sayı, özel ║
echo    ║ karakter içermeli ve en az 8 karakter    ║
echo    ║ uzunluğunda olmalıdır)                   ║
echo    ╚══════════════════════════════════════════╝
echo.

setlocal enabledelayedexpansion
:kullanici_sec_sifre
echo    ╔══════════════════════════════════════════╗
echo    ║        MEVCUT KULLANICILAR:              ║
echo    ╚══════════════════════════════════════════╝
net user | findstr /v /c:"Komut başarıyla" | findstr /v /c:"\\" | findstr /v /c:"-----"
echo.

set "kullanici="
set /p "kullanici=>> Şifresini değiştirmek istediğiniz kullanıcı adı (Geri: ESC): "
if /i "!kullanici!"=="ESC" goto sifre_yonetimi_endlocal
if "!kullanici!"=="" (
    echo    ╔══════════════════════════════════════════╗
    echo    ║        HATA: Kullanıcı adı boş!          ║
    echo    ╚══════════════════════════════════════════╝
    goto kullanici_sec_sifre
)

net user "!kullanici!" >nul 2>&1
if !errorlevel! neq 0 (
    echo    ╔══════════════════════════════════════════╗
    echo    ║ HATA: "!kullanici!" kullanıcısı yok!     ║
    echo    ╚══════════════════════════════════════════╝
    pause
    goto kullanici_sec_sifre
)

:sifre_gir
set "sifre="
set /p "sifre=>> Yeni şifreyi girin (Geri: ESC): "
if /i "!sifre!"=="ESC" goto kullanici_sec_sifre
if "!sifre!"=="" (
    echo    ╔══════════════════════════════════════════╗
    echo    ║        HATA: Şifre boş olamaz!           ║
    echo    ╚══════════════════════════════════════════╝
    goto sifre_gir
)

if "!sifre!"=="!kullanici!" (
    echo    ╔══════════════════════════════════════════╗
    echo    ║ HATA: Şifre kullanıcı adıyla aynı olamaz ║
    echo    ╚══════════════════════════════════════════╝
    goto sifre_gir
)

:sifre_onay
set "sifre_onay="
set /p "sifre_onay=>> Şifreyi tekrar girin (Onay): "
if "!sifre!" neq "!sifre_onay!" (
    echo    ╔══════════════════════════════════════════╗
    echo    ║        HATA: Şifreler uyuşmuyor!         ║
    echo    ╚══════════════════════════════════════════╝
    goto sifre_gir
)

net user "!kullanici!" "!sifre!" >nul
if !errorlevel! equ 0 (
    echo    ╔══════════════════════════════════════════╗
    echo    ║  BAŞARILI: Şifre değiştirildi!           ║
    echo    ╠══════════════════════════════════════════╣
    echo    ║ Kullanıcı: !kullanici!                   ║
    echo    ╚══════════════════════════════════════════╝
) else (
    echo    ╔══════════════════════════════════════════╗
    echo    ║ HATA: Şifre değiştirilemedi!             ║
    echo    ╠══════════════════════════════════════════╣
    echo    ║ Olası nedenler:                          ║
    echo    ║ - Şifre karmaşıklık kurallarına uymuyor  ║
    echo    ║ - Yönetici hakları eksik                 ║
    echo    ║ - Şifre çok kısa veya basit              ║
    echo    ╚══════════════════════════════════════════╝
)
pause
:sifre_yonetimi_endlocal
endlocal
goto sifre_yonetimi

:sifre_kaldir
cls
echo    ╔══════════════════════════════════════════╗
echo    ║       KULLANICI ŞİFRESİNİ KALDIR         ║
echo    ╠══════════════════════════════════════════╣
echo    ║ DİKKAT: Bu işlem kullanıcının şifresini  ║
echo    ║ tamamen kaldırır! Güvenlik riski oluş-   ║
echo    ║ turabilir!                               ║
echo    ╚══════════════════════════════════════════╝
echo.

setlocal enabledelayedexpansion
:kullanici_sec_nosifre
echo    ╔══════════════════════════════════════════╗
echo    ║        MEVCUT KULLANICILAR:              ║
echo    ╚══════════════════════════════════════════╝
net user | findstr /v /c:"Komut başarıyla" | findstr /v /c:"\\" | findstr /v /c:"-----"
echo.

set "kullanici="
set /p "kullanici=>> Şifresini kaldırmak istediğiniz kullanıcı adı (Geri: ESC): "
if /i "!kullanici!"=="ESC" goto sifre_yonetimi_endlocal2
if "!kullanici!"=="" (
    echo    ╔══════════════════════════════════════════╗
    echo    ║        HATA: Kullanıcı adı boş!          ║
    echo    ╚══════════════════════════════════════════╝
    goto kullanici_sec_nosifre
)

net user "!kullanici!" >nul 2>&1
if !errorlevel! neq 0 (
    echo    ╔══════════════════════════════════════════╗
    echo    ║ HATA: "!kullanici!" kullanıcısı yok!     ║
    echo    ╚══════════════════════════════════════════╝
    pause
    goto kullanici_sec_nosifre
)

for %%u in (Administrator Guest) do (
    if /i "!kullanici!"=="%%u" (
        echo    ╔══════════════════════════════════════════╗
        echo    ║ HATA: Sistem kullanıcıları değiştirilemez║
        echo    ╚══════════════════════════════════════════╝
