:printer_repair
cls
echo.
echo              YAZICI ONARIM ARACI - GÜVENLİ MOD
echo   Bu araç yazıcı sorunlarını gidermek için optimize edilmiştir
echo   Orijinal yazıcı ayarlarınızı korurken sorunları giderir
echo.
