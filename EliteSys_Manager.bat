:view_system_logs
@echo off
mode con: cols=82 lines=28
cls
echo ╔════════════════════════════════════════════════════════════════════════════════╗
echo ║                         SİSTEM LOGLARI GÖRÜNTÜLEME                             ║
echo ╠════════════════════════════════════════════════════════════════════════════════╣
echo ║ [1] Olay Görüntüleyici'yi Aç           [2] Son 10 Sistem Hatasını Görüntüle    ║
echo ║ [3] Son 10 Uygulama Hatasını Görüntüle [4] Son 10 Güvenlik Olayını Görüntüle   ║
echo ║ [5] Önyükleme Performans Logları       [6] Windows Update Loglarını Görüntüle  ║
echo ║ [7] Belirli Bir Olay ID'si Ara         [8] Logları Dosyaya Kaydet ve Aç        ║
echo ║ [0] Ana Menüye Dön                                                             ║
echo ╚════════════════════════════════════════════════════════════════════════════════╝
echo.
choice /c 123456780 /n /m ">> Seçiminiz (1-8,0): "
set "log_choice=%errorlevel%"

for /f "tokens=1-3 delims=." %%a in ("%date%") do (
    set "gun=%%a"
    set "ay=%%b"
    set "yil=%%c"
)
for /f "tokens=1-3 delims=:, " %%a in ("%time%") do (
    set "saat=%%a"
    set "dakika=%%b"
    set "saniye=%%c"
)
set "logfile=%temp%\temiz_log_%yil%%ay%%gun%_%saat%%dakika%%saniye%.txt"

if "%log_choice%"=="1" (
    echo Olay Görüntüleyici açılıyor...
    start eventvwr.msc
	del "%logfile%"
    goto view_system_logs
)

if "%log_choice%"=="2" (
    echo Son 10 sistem hatası dosyaya yazılıyor...
    wevtutil qe System /c:10 /f:text /rd:true /q:"*[System/Level=2]" > "%logfile%"
    notepad "%logfile%"
	del "%logfile%"
    goto view_system_logs
)

if "%log_choice%"=="3" (
    echo Son 10 uygulama hatası dosyaya yazılıyor...
    wevtutil qe Application /c:10 /f:text /rd:true /q:"*[System/Level=2]" > "%logfile%"
    notepad "%logfile%"
	del "%logfile%"
    goto view_system_logs
)

if "%log_choice%"=="4" (
    echo Son 10 güvenlik olayı dosyaya yazılıyor...
    wevtutil qe Security /c:10 /f:text /rd:true > "%logfile%"
    notepad "%logfile%"
	del "%logfile%"
    goto view_system_logs
)

if "%log_choice%"=="5" (
    echo Önyükleme performans logları dosyaya yazılıyor...
    wevtutil qe Microsoft-Windows-Diagnostics-Performance/Operational /c:20 /f:text /rd:true > "%logfile%"
    notepad "%logfile%"
	del "%logfile%"
    goto view_system_logs
)

if "%log_choice%"=="6" (
    if exist C:\Windows\WindowsUpdate.log (
        echo Windows Update Logu açılıyor...
        notepad C:\Windows\WindowsUpdate.log
    ) else (
        echo WindowsUpdate.log bulunamadı!
    )
    pause
	del "%logfile%"
    goto view_system_logs
)

if "%log_choice%"=="7" (
    set /p event_id="Aranacak Olay ID'si: "
    echo Olay ID %event_id% için arama yapılıyor...
    echo === System Logları === > "%logfile%"
    wevtutil qe System /c:20 /f:text /rd:true /q:"*[System/EventID=%event_id%]" >> "%logfile%"
    echo. >> "%logfile%"
    echo === Application Logları === >> "%logfile%"
    wevtutil qe Application /c:20 /f:text /rd:true /q:"*[System/EventID=%event_id%]" >> "%logfile%"
    notepad "%logfile%"
	del "%logfile%"
    goto view_system_logs
)

if "%log_choice%"=="8" (
    echo Loglar dosyaya kaydediliyor ve açılıyor...
    echo === Sistem Hataları === > "%logfile%"
    wevtutil qe System /c:10 /f:text /rd:true /q:"*[System/Level=2]" >> "%logfile%"
    echo. >> "%logfile%"
    echo === Uygulama Hataları === >> "%logfile%"
    wevtutil qe Application /c:10 /f:text /rd:true /q:"*[System/Level=2]" >> "%logfile%"
    echo. >> "%logfile%"
    echo === Güvenlik Olayları === >> "%logfile%"
    wevtutil qe Security /c:5 /f:text /rd:true >> "%logfile%"
    notepad "%logfile%"
	del "%logfile%"
    goto view_system_logs
)

