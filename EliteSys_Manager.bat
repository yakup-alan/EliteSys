:magnifier_key_settings
cls
echo.
echo     ╔════════════════════════════════════════════════════════╗
echo     ║             WINDOWS TUŞ KOMBİNASYONLARI                ║
echo     ╚════════════════════════════════════════════════════════╝
echo.
echo     ════════════════════════════════════════════════
echo         TUŞ AYARLARINI SEÇİNİZ:
echo     ════════════════════════════════════════════════
echo     [1]  WINDOWS + +/- TUŞLARINI AKTİF ET
echo          Windows + Artı      : Zoom aç/arttır
echo          Windows + Eksi      : Zoom azalt/kapat
echo          Hızlı zoom kontrolü
echo.
echo     [2]  WINDOWS + +/- TUŞLARINI DEVRE DIŞI BIRAK
echo          Tuş kombinasyonları çalışmaz
echo          Manuel kontrol gerekir
echo.
echo     [3]   ÖZEL ZOOM AYARLARI
echo          Zoom seviyesi ayarla
echo          Büyüteç modu seç
echo.
echo     [0]   GERİ DÖN
echo.

choice /c 1230 /n /m "Seçiminiz [1,2,3,0]: "

if %errorlevel% equ 1 goto magnifier_enable_keys
if %errorlevel% equ 2 goto magnifier_disable_keys
if %errorlevel% equ 3 goto magnifier_custom_zoom
if %errorlevel% equ 4 goto windows_magnifier

:magnifier_enable_keys
cls
echo.
echo     WINDOWS + +/- TUSLARI AKTIF EDILIYOR...
echo.

reg delete "HKCU\Software\Microsoft\Windows\CurrentVersion\Policies\Explorer" /v "NoWinKeys" /f >nul 2>&1
reg add "HKCU\Software\Microsoft\ScreenMagnifier" /v "WinKeyEnabled" /t REG_DWORD /d 1 /f >nul 2>&1
reg add "HKCU\Control Panel\Accessibility\Magnifier" /v "MagnifierHotkeysEnabled" /t REG_DWORD /d 1 /f >nul 2>&1

echo.
echo     WINDOWS + +/- TUSLARI AKTIF EDILDI!
echo.
echo     Not: Degisikligin tam uygulanmasi icin oturumu kapatip acmak gerekebilir.
echo.
echo     Windows + [+] : Zoom'u acar ve arttirir
echo     Windows + [-] : Zoom'u azaltir
echo.
pause
goto magnifier_key_settings

:magnifier_custom_zoom
cls
echo.
echo     ╔════════════════════════════════════════════════════════╗
echo     ║                   ÖZEL ZOOM AYARLARI                   ║
echo     ╚════════════════════════════════════════════════════════╝
echo.
echo     ════════════════════════════════════════════════
echo         ZOOM SEVİYESİ SEÇİNİZ:
echo     ════════════════════════════════════════════════
echo     [1]  DÜŞÜK  (%%100-200)
echo     [2]  ORTA   (%%200-400) 
echo     [3]  YÜKSEK (%%400-800)
echo     [4]   ÖZEL DEĞER GİR
echo.
echo     [0]   GERİ DÖN
echo.

set /p zoom_secim=">> Seçiminiz [1,2,3,4,0]: "
if "%zoom_secim%"=="" goto magnifier_custom_zoom

if "%zoom_secim%"=="1" (
    reg add "HKCU\Software\Microsoft\ScreenMagnifier" /v "Magnification" /t REG_DWORD /d 200 /f >nul 2>&1
    echo      Zoom seviyesi %%200 olarak ayarlandı!
)
if "%zoom_secim%"=="2" (
    reg add "HKCU\Software\Microsoft\ScreenMagnifier" /v "Magnification" /t REG_DWORD /d 400 /f >nul 2>&1
    echo      Zoom seviyesi %%400 olarak ayarlandı!
)
if "%zoom_secim%"=="3" (
    reg add "HKCU\Software\Microsoft\ScreenMagnifier" /v "Magnification" /t REG_DWORD /d 600 /f >nul 2>&1
    echo      Zoom seviyesi %%600 olarak ayarlandı!
)
if "%zoom_secim%"=="4" (
    set /p zoom_level="Zoom seviyesi girin (100-1600): "
    reg add "HKCU\Software\Microsoft\ScreenMagnifier" /v "Magnification" /t REG_DWORD /d %zoom_level% /f >nul 2>&1
    echo      Zoom seviyesi %%%zoom_level%% olarak ayarlandı!
)
if "%zoom_secim%"=="0" goto magnifier_key_settings

echo.
pause
goto magnifier_custom_zoom

:magnifier_disable_keys
cls
echo.
echo     WINDOWS + +/- TUSLARI DEVRE DISI BIRAKILIYOR...
echo.

reg add "HKCU\Software\Microsoft\ScreenMagnifier" /v "WinKeyEnabled" /t REG_DWORD /d 0 /f >nul 2>&1
reg add "HKCU\Control Panel\Accessibility\Magnifier" /v "MagnifierHotkeysEnabled" /t REG_DWORD /d 0 /f >nul 2>&1

echo.
echo     WINDOWS + +/- TUSLARI DEVRE DISI BIRAKILDI!
echo.
echo     Not: Degisikligin tam uygulanmasi icin oturumu kapatip acmak gerekebilir.
echo.
pause
goto magnifier_key_settings

:reset_magnifier
cls
echo.
echo     BÜYÜTEÇ AYARLARI SIFIRLANIYOR...
echo.

reg delete "HKCU\Software\Microsoft\ScreenMagnifier" /f >nul 2>&1
reg delete "HKCU\Control Panel\Accessibility\Magnifier" /f >nul 2>&1
reg delete "HKCU\Software\Microsoft\Windows\CurrentVersion\Policies\Explorer" /v "NoMagnifier" /f >nul 2>&1
reg delete "HKCU\Software\Microsoft\Windows\CurrentVersion\Policies\Explorer" /v "NoWinKeys" /f >nul 2>&1
reg delete "HKCU\Software\Microsoft\Windows\CurrentVersion\Ease of Access" /v "Magnifier" /f >nul 2>&1

net session >nul 2>&1
if not errorlevel 1 (
    icacls "%SystemRoot%\System32\magnify.exe" /grant Everyone:RX >nul 2>&1
)

taskkill /f /im magnify.exe >nul 2>&1
taskkill /f /im Utilman.exe >nul 2>&1
taskkill /f /im explorer.exe >nul 2>&1
timeout /t 2 /nobreak >nul
start explorer.exe

