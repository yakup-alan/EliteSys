:windows_optimize_menu
mode con: cols=82 lines=30
cls
echo.
echo 	╔════════════════════════════════════════════════════════╗
echo 	║       WINDOWS PERFORMANS VE KARARLILIK ARTTIRICI       ║
echo 	╠════════════════════════════════════════════════════════╣
echo 	║    [1] Optimize Et (Performans Modu)                   ║
echo 	║    [2] Geri Al (Varsayılan Ayarlar)                    ║
