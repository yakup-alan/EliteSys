:download_rdp
echo Microsoft Uzak Masaüstü İndiriliyor ve Kuruluyor...
echo.
echo İndirme başlıyor... Lütfen bekleyin.

if exist "%TEMP%\MicrosoftRemoteDesktop.exe" del "%TEMP%\MicrosoftRemoteDesktop.exe"

powershell -Command "Start-BitsTransfer -Source 'https://go.microsoft.com/fwlink/?linkid=2247659' -Destination '%TEMP%\MicrosoftRemoteDesktop.exe'"

if exist "%TEMP%\MicrosoftRemoteDesktop.exe" (
    echo  İndirme tamamlandı! Dosya boyutu:
    for %%I in ("%TEMP%\MicrosoftRemoteDesktop.exe") do echo   %%~zI byte
    echo.
    echo Kurulum başlatılıyor...
    timeout /t 2 >nul
    start "" /wait "%TEMP%\MicrosoftRemoteDesktop.exe"
    echo.
    echo  Kurulum tamamlandı!
    echo Microsoft Uzak Masaüstü başarıyla kuruldu.
    echo Başlat menüsünden "Uzak Masaüstü" yazarak bulabilirsiniz.
) else (
    echo.
    echo  İndirme başarısız!
    echo Alternatif yöntem deneniyor...
    
    echo.
    echo Lütfen tarayıcıdan manuel indirme yapın:
    echo https://www.microsoft.com/tr-tr/p/microsoft-remote-desktop/9wzdncrfj3ps
    echo.
    echo Tarayıcıyı açıyorum...
    timeout /t 3 >nul
    start "" "https://www.microsoft.com/tr-tr/p/microsoft-remote-desktop/9wzdncrfj3ps"
)

echo.
pause
goto remote_tools_menu

:rdp_enable
echo Windows RDP (Uzak Masaüstü) Etkinleştiriliyor...
echo.

echo 1. Registry ayarları yapılıyor...
reg add "HKLM\System\CurrentControlSet\Control\Terminal Server" /v fDenyTSConnections /t REG_DWORD /d 0 /f

echo 2. Güvenlik duvarı kuralları etkinleştiriliyor...
netsh advfirewall firewall set rule group="Uzak Masaüstü" new enable=Yes >nul 2>&1
netsh advfirewall firewall set rule group="Remote Desktop" new enable=Yes >nul 2>&1

echo 3. RDP servisi başlatılıyor...
sc config TermService start= auto >nul 2>&1
net start TermService >nul 2>&1

echo 4. Kullanıcı izinleri ayarlanıyor...
net localgroup "Uzak Masaüstü Kullanıcıları" %USERNAME% /add >nul 2>&1
net localgroup "Remote Desktop Users" %USERNAME% /add >nul 2>&1

echo.
echo  RDP BAŞARIYLA ETKİNLEŞTİRİLDİ!
echo.
echo  BAĞLANTI BİLGİLERİ:
echo    Bilgisayar Adı: %COMPUTERNAME%
echo    Kullanıcı: %USERNAME%
echo.
echo  NOT: Windows şifrenizle bağlanabilirsiniz.
echo.
pause
goto remote_tools_menu

:downloadAndCopy
set "url=%~1"
set "filename=%~2"
set "tempFile=%tempDir%\%filename%"
set "destFile=%destFolder%\%filename%"

if not exist "%destFolder%" mkdir "%destFolder%"
if not exist "%tempDir%" mkdir "%tempDir%"

echo.
echo İndiriliyor: %filename%
echo URL: %url%
echo.

powershell -Command ^
    "$ProgressPreference = 'SilentlyContinue';" ^
    "try {" ^
        "Invoke-WebRequest -Uri '%url%' -OutFile '%tempFile%' -ErrorAction Stop;" ^
        "if (Test-Path '%tempFile%') {" ^
            "$fileSize = (Get-Item '%tempFile%').Length / 1KB;" ^
            "Write-Output '[OK] İndirme tamamlandı. Dosya boyutu: ' + [math]::Round($fileSize, 2) + ' KB';" ^
            "Copy-Item '%tempFile%' '%destFile%' -Force;" ^
            "Remove-Item '%tempFile%' -Force;" ^
            "if (Test-Path '%destFile%') {" ^
                "Write-Output '[OK] Dosya kopyalandı: %destFile%';" ^
                "Write-Output 'Klasör açılıyor...';" ^
                "Start-Process explorer.exe -ArgumentList '%destFolder%';" ^
            "} else {" ^
                "Write-Output '[HATA] Dosya kopyalanamadı';" ^
            "}" ^
        "} else {" ^
            "Write-Output '[HATA] Dosya indirilemedi';" ^
        "}" ^
    "} catch {" ^
        "Write-Output '[HATA] İndirme hatası: ' + $_.Exception.Message;" ^
    "}"

echo.
pause
exit /b

