:office365_install
cls
color 0E
echo.
echo     ╔════════════════════════════════════════════════════════╗
echo     ║                 OFFICE365 KURULUMU                     ║
echo     ╠════════════════════════════════════════════════════════╣
echo     ║ Bu işlem GitHub'dan Office365 kurulum dosyalarını      ║
echo     ║ indirip çalıştıracaktır.                               ║
echo     ║                                                        ║
echo     ║ İnternet bağlantınızın olduğundan emin olun.           ║
echo     ╚════════════════════════════════════════════════════════╝
echo.
echo [1] Devam et
echo [0] Geri dön
echo.
choice /c 10 /n /m ">> Seçiminiz [1,0]: "
if errorlevel 2 goto win_iso_download

set "desktop=%USERPROFILE%\Desktop"
set "office_dir=%desktop%\Office365"
set "temp_zip=%TEMP%\Office365_Repo.zip"
set "repo_url=https://github.com/abdullah-erturk/Office-365-Enterprise-Setup/archive/refs/heads/main.zip"

echo.
echo [!] İşlem başlatılıyor, lütfen bekleyin...
echo.

if not exist "%office_dir%" mkdir "%office_dir%" 2>nul
echo [1/4] GitHub reposu indiriliyor (curl)...
curl -L -o "%temp_zip%" "%repo_url%" --progress-bar 2>nul
if errorlevel 1 (
    echo [HATA] curl ile indirme başarısız, alternatif yöntem deneniyor...
    bitsadmin /transfer "Office365Download" /download /priority high "%repo_url%" "%temp_zip%" >nul
)
if not exist "%temp_zip%" (
    echo [HATA] Dosya indirilemedi! İnternet bağlantınızı kontrol edin.
    pause
    goto win_iso_download
)
echo [2/4] Dosyalar çıkartılıyor...
set "temp_extract=%TEMP%\Office365_Extract"
if exist "%temp_extract%" rmdir /s /q "%temp_extract%" 2>nul
mkdir "%temp_extract%"
powershell -Command "Expand-Archive -Path '%temp_zip%' -DestinationPath '%temp_extract%' -Force" 2>nul
echo [3/4] Office365 dosyaları kopyalanıyor...
set "source_dir=%temp_extract%\Office-365-Enterprise-Setup-main\Office365"
if exist "%source_dir%" (
    xcopy /e /y /q "%source_dir%\*" "%office_dir%\" >nul
) else (
    xcopy /e /y /q "%temp_extract%\Office-365-Enterprise-Setup-main\*" "%office_dir%\" >nul
)
del /f /q "%temp_zip%" 2>nul
rmdir /s /q "%temp_extract%" 2>nul
echo [4/4] Office365 klasörü açılıyor...
start "" "%office_dir%"

set "install_bat="
for %%f in ("%office_dir%\*.bat") do (
    if /i "%%~nxf"=="Office365_Install.bat" set "install_bat=%%f"
)
if defined install_bat (
    echo Office365 kurulumu arka planda başlatılıyor...
    start "Office365 Kurulumu" "%install_bat%"
) else (
    echo [UYARI] Office365_Install.bat bulunamadı, lütfen manuel olarak çalıştırın.
)

echo.
echo  İşlem tamamlandı. Windows ISO menüsüne dönülüyor...
timeout /t 2 >nul
goto win_iso_download

echo.
echo  Office365 kurulum işlemi başlatıldı. Ana menüye dönülüyor...
timeout /t 2 >nul
goto ana_menu

if "%mctchoice%"=="6" (
    start https://www.tnctr.com/forum/112-multiboot-sistemler
    goto win_iso_download
)

if "%mctchoice%"=="7" (
    start https://www.tnctr.com/topic/1233742-vadi-e-spor-multiboot-v4/
    goto win_iso_download
)

