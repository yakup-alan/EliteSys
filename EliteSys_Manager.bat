echo. >> "%rapor_dosyasi%"

cls
echo ======================================================
echo          WINDOWS DEFENDER DETAYLI KONTROL
echo ======================================================
echo.
echo [!] Rapor dosyası oluşturuluyor: %rapor_dosyasi%
echo.

echo [1/5] Defender Servis Kontrolü yapılıyor...
echo [1/5] SERVİS KONTROLÜ: >> "%rapor_dosyasi%"
powershell -Command "$s = Get-Service -Name WinDefend -ErrorAction SilentlyContinue; if ($s) { 'Durum: ' + $s.Status + ' | Başlangıç: ' + $s.StartType } else { 'Servis Bulunamadı' }" >> "%rapor_dosyasi%"

echo [2/5] Defender Temel Durum Kontrolü yapılıyor...
echo. >> "%rapor_dosyasi%"
echo [2/5] TEMEL DURUM: >> "%rapor_dosyasi%"
powershell -Command "try { $s = Get-MpComputerStatus -ErrorAction Stop; 'Antivirus Aktif: ' + $s.AntivirusEnabled; 'Gerçek Zamanlı Koruma: ' + $s.RealTimeProtectionEnabled; 'Antispyware Aktif: ' + $s.AntispywareEnabled } catch { 'Erişim Sağlanamadı' }" >> "%rapor_dosyasi%"

echo [3/5] Defender Koruma Ayarları Kontrol Ediliyor...
echo. >> "%rapor_dosyasi%"
echo [3/5] KORUMA AYARLARI: >> "%rapor_dosyasi%"
powershell -Command "try { $s = Get-MpComputerStatus -ErrorAction Stop; 'Davranış İzleme: ' + $s.BehaviorMonitoringEnabled; 'IOAV Koruması: ' + $s.IOAVProtectionEnabled; 'Ağ Koruması (NIS): ' + $s.NISEnabled } catch { 'Erişim Sağlanamadı' }" >> "%rapor_dosyasi%"

echo [4/5] Defender İmza ve Tarama Bilgileri...
echo. >> "%rapor_dosyasi%"
echo [4/5] İMZA VE TARAMA: >> "%rapor_dosyasi%"
powershell -Command "try { $s = Get-MpComputerStatus -ErrorAction Stop; 'İmza Yaşı: ' + $s.AntivirusSignatureAge + ' gün'; 'Son Hızlı Tarama: ' + $s.LastQuickScanDateTime; 'Motor Sürümü: ' + $s.AntivirusEngineVersion } catch { 'Erişim Sağlanamadı' }" >> "%rapor_dosyasi%"

echo [5/5] Defender Güvenlik Düzeni Kontrolü...
echo. >> "%rapor_dosyasi%"
echo [5/5] GÜVENLİK DÜZENİ (Kısıtlamalar): >> "%rapor_dosyasi%"
powershell -Command "try { $p = Get-MpPreference -ErrorAction Stop; 'GZ İzleme Devre Dışı mı?: ' + $p.DisableRealtimeMonitoring; 'IOAV Devre Dışı mı?: ' + $p.DisableIOAVProtection } catch { 'Erişim Sağlanamadı' }" >> "%rapor_dosyasi%"

echo.
echo ======================================================
echo                  ÖZET BİLGİLER
echo ======================================================
echo.

for /f "tokens=*" %%A in ('powershell -Command "Get-Service -Name WinDefend -ErrorAction SilentlyContinue | Select-Object -ExpandProperty Status"') do echo Servis Durumu    : %%A
for /f "tokens=*" %%A in ('powershell -Command "(Get-MpComputerStatus).AntivirusEnabled"') do echo Antivirüs Aktif  : %%A
for /f "tokens=*" %%A in ('powershell -Command "(Get-MpComputerStatus).RealTimeProtectionEnabled"') do echo G.Z. Koruma     : %%A
for /f "tokens=*" %%A in ('powershell -Command "(Get-MpComputerStatus).AntivirusSignatureAge"') do echo İmza Yaşı       : %%A gün

echo.
echo ======================================================
echo                SONUÇ DEĞERLENDİRMESİ
echo ======================================================
echo.

set "sonuc_mesaji=Bilinmiyor"
for /f "tokens=*" %%A in ('powershell -Command "$s = Get-MpComputerStatus; if ($s.AntivirusEnabled -and $s.RealTimeProtectionEnabled) { 'GÜVENLİ: Defender Tam Aktif' } elseif ($s.AntivirusEnabled) { 'UYARI: Aktif ama G.Z. Koruma Kapalı' } else { 'RİSKLİ: Defender Devre Dışı' }"') do set "sonuc_mesaji=%%A"

echo DURUM: %sonuc_mesaji%
echo. >> "%rapor_dosyasi%"
echo SONUÇ DEĞERLENDİRMESİ: >> "%rapor_dosyasi%"
echo %sonuc_mesaji% >> "%rapor_dosyasi%"

echo.
echo [!] İşlem tamamlandı. Rapor dosyaya kaydedildi.
echo [!] Dosyayı açmak için bir tuşa basın...
pause >nul
start notepad.exe "%rapor_dosyasi%"

goto defender_menu

:digital_imza_menu
mode con: cols=82 lines=30
color 0A
set SmartScreen=
set AppLocker=
set WDAC=
set WDAC_Status=
set ControlledFolder=
set PUAProtection=
set NetworkProtection=
cls
call :get_status_imza

echo ╔════════════════════════════════════════════════════════════════════════════════╗
echo ║                     DİJİTAL İMZA KISITLAMALARI YÖNETİMİ            
echo ╠════════════════════════════════════════════════════════════════════════════════╣
echo ║ DURUM: ( = Açık / = Kapalı)                     
echo ╠════════════════════════════════════════════════════════════════════════════════╣
echo ║ SmartScreen                : %SmartScreen%                             
echo ║ AppLocker Servisi          : %AppLocker%                                     
echo ║ WDAC Politikası            : %WDAC% (%WDAC_Status%)                       
echo ║ Controlled Folder Access   : %ControlledFolder%                            
echo ║ Defender PUA Koruması      : %PUAProtection%                                 
echo ║ Defender Network Koruması  : %NetworkProtection%                            
echo ╠════════════════════════════════════════════════════════════════════════════════╣
echo ║ [1] Tüm kısıtlamaları KAPAT (Güvenliği azalt)                              
echo ║ [2] Tüm kısıtlamaları AÇ (Güvenliği artır)                                   
echo ║ [0] Ana Menüye Dön                                                           
echo ╚════════════════════════════════════════════════════════════════════════════════╝

choice /c 120 /n /m ">> Seçiminiz : "

if errorlevel 3 goto ana_menu
if errorlevel 2 goto :Digital_imza_enable
if errorlevel 1 goto :Digital_imza_disable

:get_status_imza
for /f "tokens=3*" %%a in ('reg query "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer" /v SmartScreenEnabled 2^>nul') do (
    if /i "%%a"=="Off" (
        set SmartScreen= Kapalı
    ) else (
        set SmartScreen= Açık
    )
)

sc query AppIDSvc | findstr /i "RUNNING" >nul
if %errorlevel%==0 (
    set AppLocker= Açık
) else (
    set AppLocker= Kapalı
)

if exist "C:\Windows\System32\CodeIntegrity\SiPolicy.p7b" (
    set WDAC= Yüklü
    set WDAC_Status=Etkin
) else if exist "C:\Windows\System32\CodeIntegrity\SiPolicy.p7b.bak" (
    set WDAC= Devre Dışı
    set WDAC_Status=Yedekte
) else (
    set WDAC= Yok
    set WDAC_Status=-
)

for /f "delims=" %%a in ('powershell -Command "(Get-MpPreference).EnableControlledFolderAccess"') do (
    if "%%a"=="1" (
        set ControlledFolder= Açık
    ) else (
        set ControlledFolder= Kapalı
    )
)

for /f "delims=" %%a in ('powershell -Command "(Get-MpPreference).PUAProtection"') do (
    if "%%a"=="1" (
        set PUAProtection= Açık
    ) else (
        set PUAProtection= Kapalı
    )
)

for /f "delims=" %%a in ('powershell -Command "(Get-MpPreference).EnableNetworkProtection"') do (
    if "%%a"=="1" (
        set NetworkProtection= Açık
    ) else (
        set NetworkProtection= Kapalı
    )
)

exit /b

:Digital_imza_disable
cls
echo [UYARI] Bu işlem sistem güvenliğini azaltacaktır!
echo Devam etmek istiyor musunuz?
choice /c EH /n /m "(E=Devam, H=İptal): "
if errorlevel 2 goto :digital_imza_menu

cls
echo [*] Kısıtlamalar devre dışı bırakılıyor...

echo - SmartScreen devre dışı...
reg add "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer" /v SmartScreenEnabled /t REG_SZ /d Off /f >nul || echo [!] SmartScreen devre dışı bırakılamadı!
reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\System" /v EnableSmartScreen /t REG_DWORD /d 0 /f >nul
reg add "HKLM\SOFTWARE\Policies\Microsoft\MicrosoftEdge\PhishingFilter" /v EnabledV9 /t REG_DWORD /d 0 /f >nul

echo - AppLocker servisi kapatılıyor...
sc stop AppIDSvc >nul 2>&1
if %errorlevel% neq 0 echo [!] AppLocker servisi durdurulamadı!
sc config AppIDSvc start= disabled >nul

echo - WDAC politika dosyası devre dışı bırakılıyor...
if exist "C:\Windows\System32\CodeIntegrity\SiPolicy.p7b" (
    ren "C:\Windows\System32\CodeIntegrity\SiPolicy.p7b" "SiPolicy.p7b.bak" >nul 2>&1
    if exist "C:\Windows\System32\CodeIntegrity\SiPolicy.p7b.bak" (
        echo [+] WDAC politikası devre dışı bırakıldı (yedek oluşturuldu)
    ) else (
        echo [!] WDAC politikası devre dışı bırakılamadı!
    )
) else (
    echo [i] WDAC politikası zaten devre dışı
)

echo - Defender gelişmiş koruma ayarları devre dışı...
powershell -Command "Set-MpPreference -EnableControlledFolderAccess Disabled" >nul
powershell -Command "Set-MpPreference -PUAProtection Disabled" >nul
powershell -Command "Set-MpPreference -EnableNetworkProtection Disabled" >nul

echo.
echo [] Tüm kısıtlamalar devre dışı bırakıldı.
pause
goto :digital_imza_menu

:Digital_imza_enable
cls
echo [UYARI] Bu işlem sistem güvenliğini artıracaktır!
echo Devam etmek istiyor musunuz?
choice /c EH /n /m "(E=Devam, H=İptal): "
if errorlevel 2 goto :digital_imza_menu

cls
echo [*] Kısıtlamalar tekrar etkinleştiriliyor...

echo - SmartScreen etkinleştiriliyor...
reg add "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer" /v SmartScreenEnabled /t REG_SZ /d RequireAdmin /f >nul || echo [!] SmartScreen etkinleştirilemedi!
reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\System" /v EnableSmartScreen /t REG_DWORD /d 1 /f >nul
reg add "HKLM\SOFTWARE\Policies\Microsoft\MicrosoftEdge\PhishingFilter" /v EnabledV9 /t REG_DWORD /d 1 /f >nul

echo - AppLocker servisi açılıyor...
sc config AppIDSvc start= demand >nul
sc start AppIDSvc >nul 2>&1
if %errorlevel% neq 0 echo [!] AppLocker servisi başlatılamadı!

echo - WDAC politikası geri yükleniyor...
if exist "C:\Windows\System32\CodeIntegrity\SiPolicy.p7b.bak" (
    ren "C:\Windows\System32\CodeIntegrity\SiPolicy.p7b.bak" "SiPolicy.p7b" >nul 2>&1
    if exist "C:\Windows\System32\CodeIntegrity\SiPolicy.p7b" (
        echo [+] WDAC politikası geri yüklendi
    ) else (
        echo [!] WDAC politikası geri yüklenemedi!
    )
) else (
    echo [i] WDAC yedek dosyası bulunamadı
)

echo - Defender gelişmiş koruma ayarları etkinleştiriliyor...
powershell -Command "Set-MpPreference -EnableControlledFolderAccess Enabled" >nul
powershell -Command "Set-MpPreference -PUAProtection Enabled" >nul
powershell -Command "Set-MpPreference -EnableNetworkProtection Enabled" >nul

echo.
echo [] Tüm kısıtlamalar etkinleştirildi.
pause
goto :digital_imza_menu

:donanim_bilgisi
color 1A
